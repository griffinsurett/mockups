---
import Logo from './Logo.astro';
---
<section class="relative w-full h-[600px] flex items-center justify-center text-center">
  <!-- Background image with dark overlay -->
  <div class="absolute inset-0 z-0">
    <img src="/assets/images/hero.png" alt="Car interior detailing" class="w-full h-full object-cover object-center" />
    <div class="absolute inset-0 bg-black/60"></div>
  </div>

  <!-- Hero Content -->
  <div class="relative z-10 flex flex-col items-center px-4 mt-8">
    <div class="hidden md:block">
      <Logo class="w-56 md:w-72 mb-6" />
    </div>
    
    <h1 class="font-serif text-4xl md:text-6xl text-white font-bold max-w-4xl leading-tight mb-6 drop-shadow-xl" style="text-shadow: 2px 2px 4px rgba(0,0,0,0.5);">
      ELEVATING CARS TO A HIGHER CLASS OF CLEAN
    </h1>
    
    <p class="font-sans text-white text-lg md:text-xl font-bold tracking-[0.2em] uppercase mb-10 drop-shadow-md">
      DRIVEN BY DETAIL, POWERED BY PERFECTION.
    </p>
    
    <a href="#" class="border-2 border-white text-white font-sans font-bold text-sm tracking-widest py-3 px-8 hover:bg-white hover:text-black transition-colors duration-300 uppercase rounded-sm bg-black/20 hover:bg-white">
      BOOK YOUR DETAIL TODAY
    </a>
  </div>
</section>
