---
<section class="w-full grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 border-b-[6px] border-[var(--color-brand-primary)]">
  <!-- Card 1 -->
  <div class="relative h-[350px] md:h-[400px] w-full overflow-hidden group border-r border-gray-900/50">
    <img src="/assets/images/packages.png" alt="Detailing Packages" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
    <div class="absolute inset-0 bg-gradient-to-t from-black via-black/60 to-transparent opacity-90 group-hover:opacity-100 transition-opacity duration-300"></div>
    <div class="absolute inset-0 p-8 flex flex-col justify-end items-start z-10">
      <h3 class="font-sans font-extrabold text-[15px] md:text-[17px] text-white uppercase mb-4 tracking-wide drop-shadow-md">DETAILING PACKAGES</h3>
      <a href="#" class="border-2 border-white text-white text-[11px] font-bold uppercase py-2 px-6 hover:bg-white hover:text-black transition-colors tracking-widest backdrop-blur-sm bg-black/10">
        CONTACT US
      </a>
    </div>
  </div>
  
  <!-- Card 2 -->
  <div class="relative h-[350px] md:h-[400px] w-full overflow-hidden group border-r border-gray-900/50">
    <img src="/assets/images/luxury-car.png" alt="Ceramic Coating" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
    <div class="absolute inset-0 bg-gradient-to-t from-black via-black/60 to-transparent opacity-90 group-hover:opacity-100 transition-opacity duration-300"></div>
    <div class="absolute inset-0 p-8 flex flex-col justify-end items-start z-10">
      <h3 class="font-sans font-extrabold text-[15px] md:text-[17px] text-white uppercase mb-4 tracking-wide drop-shadow-md">CERAMIC COATING</h3>
      <a href="#" class="border-2 border-white text-white text-[11px] font-bold uppercase py-2 px-6 hover:bg-white hover:text-black transition-colors tracking-widest backdrop-blur-sm bg-black/10">
        LEARN MORE
      </a>
    </div>
  </div>

  <!-- Card 3 -->
  <div class="relative h-[350px] md:h-[400px] w-full overflow-hidden group border-r border-gray-900/50">
    <img src="/assets/images/membership.png" alt="Membership Program" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
    <div class="absolute inset-0 bg-gradient-to-t from-black via-black/60 to-transparent opacity-90 group-hover:opacity-100 transition-opacity duration-300"></div>
    <div class="absolute inset-0 p-8 flex flex-col justify-end items-start z-10">
      <h3 class="font-sans font-extrabold text-[15px] md:text-[17px] text-white uppercase mb-4 tracking-wide drop-shadow-md">MEMBERSHIP PROGRAM</h3>
      <a href="#" class="border-2 border-white text-white text-[11px] font-bold uppercase py-2 px-6 hover:bg-white hover:text-black transition-colors tracking-widest backdrop-blur-sm bg-black/10">
        BECOME A MEMBER
      </a>
    </div>
  </div>

  <!-- Card 4 -->
  <div class="relative h-[350px] md:h-[400px] w-full overflow-hidden group">
    <img src="/assets/images/fleet.png" alt="Fleet Cleanings" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
    <div class="absolute inset-0 bg-gradient-to-t from-black via-black/60 to-transparent opacity-90 group-hover:opacity-100 transition-opacity duration-300"></div>
    <div class="absolute inset-0 p-8 flex flex-col justify-end items-start z-10">
      <h3 class="font-sans font-extrabold text-[15px] md:text-[17px] text-white uppercase mb-4 tracking-wide drop-shadow-md">FLEET CLEANINGS</h3>
      <a href="#" class="border-2 border-white text-white text-[11px] font-bold uppercase py-2 px-6 hover:bg-white hover:text-black transition-colors tracking-widest backdrop-blur-sm bg-black/10">
        LEARN MORE
      </a>
    </div>
  </div>
</section>
