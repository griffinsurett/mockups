---
---
<section class="w-full bg-[#030712] py-24 px-8 md:px-16 border-b-[6px] border-[var(--color-brand-primary)] overflow-hidden relative">
  <!-- Glowing Background Orbs -->
  <div class="absolute top-1/4 left-1/4 w-[400px] h-[400px] bg-[var(--color-brand-primary)]/10 rounded-full blur-[120px] pointer-events-none z-0"></div>
  <div class="absolute bottom-1/4 right-1/4 w-[400px] h-[400px] bg-yellow-500/5 rounded-full blur-[150px] pointer-events-none z-0"></div>

  <div class="max-w-7xl mx-auto relative z-10">
    <!-- Header -->
    <div class="flex flex-col items-center mb-16 text-center">
      <span class="font-sans text-xs md:text-sm font-black tracking-[0.3em] text-[#df9c2c] uppercase mb-3">EXCLUSIVE PROMOTION</span>
      <h2 class="font-serif text-3xl md:text-[42px] text-white font-bold leading-tight mb-6 drop-shadow-xl uppercase">
        MAY MONTHLY SPECIAL
      </h2>
      <div class="w-12 h-1 bg-[var(--color-brand-primary)] shadow-[0_0_10px_rgba(28,117,188,0.5)]"></div>
    </div>

    <!-- Main Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-stretch">
      
      <!-- Left Column: Chiron Graphic and Served Cities (5 Columns) -->
      <div class="lg:col-span-5 flex flex-col justify-between bg-black border border-gray-900 overflow-hidden relative group p-6">
        <!-- Bugatti Image -->
        <div class="w-full aspect-[16/10] overflow-hidden relative border border-gray-900">
          <img src="/assets/images/special.png" alt="May Monthly Special Bugatti Chiron" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent pointer-events-none"></div>
          
          <!-- May Special Tag -->
          <div class="absolute top-4 left-4 bg-red-600 text-white text-[10px] font-black px-3 py-1 uppercase tracking-widest shadow-lg animate-pulse">
            MAY SPECIAL
          </div>
        </div>

        <!-- Cities List (Green bar representing the ad flyer exactly) -->
        <div class="mt-6">
          <div class="bg-[#1b5e20]/20 border border-[#2e7d32] p-4 rounded-sm">
            <h4 class="font-sans text-[11px] font-black text-[#4caf50] uppercase tracking-widest mb-3 flex items-center gap-2">
              <i class="ph-fill ph-map-pin text-sm"></i> SERVING CENTRAL FLORIDA
            </h4>
            <p class="font-sans text-[11px] text-gray-300 leading-relaxed font-semibold">
              Daytona Beach &bull; Ocala &bull; The Villages &bull; Clermont &bull; Winter Garden &bull; Orlando &bull; Oviedo &bull; Altamonte Springs &bull; Apopka &bull; Winter Park &bull; Deland &bull; Orange City
            </p>
          </div>
        </div>

        <!-- Mother's Day Badge -->
        <div class="mt-6 bg-gradient-to-r from-[#5c3c15] via-[#8c6239] to-[#5c3c15] border border-[#df9c2c] p-5 text-center relative overflow-hidden">
          <div class="absolute inset-0 bg-white/5 pointer-events-none"></div>
          <h4 class="font-sans text-xs font-black text-[#ffffff] uppercase tracking-widest mb-1">MOTHER'S DAY EXCLUSIVE</h4>
          <p class="font-serif text-lg font-bold text-[#df9c2c]">ALL MOMS GET 15% OFF</p>
          <p class="font-sans text-[10px] text-white/80 uppercase tracking-wider mt-1">The Entire Month of May &bull; All Makes & Models</p>
        </div>
      </div>

      <!-- Right Column: Deal Details (7 Columns) -->
      <div class="lg:col-span-7 bg-black border border-gray-900 p-8 md:p-10 flex flex-col justify-between relative">
        <!-- Price Banner -->
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center border-b border-gray-900 pb-8 mb-8 gap-4">
          <div class="flex flex-col">
            <span class="font-sans text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">ALL MAKES & MODELS</span>
            <h3 class="font-serif text-2xl md:text-3xl text-white font-bold">Full Interior & Exterior Detail</h3>
          </div>
          <div class="flex items-baseline gap-2">
            <span class="font-serif text-4xl md:text-5xl font-black text-[#df9c2c]">$199.99</span>
          </div>
        </div>

        <!-- 9 Premium Inclusions Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-10">
          
          <!-- Inclusion 1 -->
          <div class="flex items-start gap-3 group/item">
            <i class="ph-fill ph-cloud-fog text-xl text-[#df9c2c] bg-[#df9c2c]/10 p-2 rounded-sm group-hover/item:bg-[#df9c2c] group-hover/item:text-black transition-all"></i>
            <div class="flex flex-col">
              <span class="font-sans text-xs font-black text-white uppercase tracking-wider">STEAM CLEANED SEATS</span>
              <span class="font-sans text-[11px] text-gray-400 leading-normal mt-0.5">Deep extraction for seats & flooring</span>
            </div>
          </div>

          <!-- Inclusion 2 -->
          <div class="flex items-start gap-3 group/item">
            <i class="ph-fill ph-drop text-xl text-[#df9c2c] bg-[#df9c2c]/10 p-2 rounded-sm group-hover/item:bg-[#df9c2c] group-hover/item:text-black transition-all"></i>
            <div class="flex flex-col">
              <span class="font-sans text-xs font-black text-white uppercase tracking-wider">RAIN-X TREATMENT</span>
              <span class="font-sans text-[11px] text-gray-400 leading-normal mt-0.5">Applied to all clean glass surfaces</span>
            </div>
          </div>

          <!-- Inclusion 3 -->
          <div class="flex items-start gap-3 group/item">
            <i class="ph-fill ph-sparkles text-xl text-[#df9c2c] bg-[#df9c2c]/10 p-2 rounded-sm group-hover/item:bg-[#df9c2c] group-hover/item:text-black transition-all"></i>
            <div class="flex flex-col">
              <span class="font-sans text-xs font-black text-white uppercase tracking-wider">PLASTIC PROTECTION</span>
              <span class="font-sans text-[11px] text-gray-400 leading-normal mt-0.5">Applied to all interior plastic paneling</span>
            </div>
          </div>

          <!-- Inclusion 4 -->
          <div class="flex items-start gap-3 group/item">
            <i class="ph-fill ph-shield text-xl text-[#df9c2c] bg-[#df9c2c]/10 p-2 rounded-sm group-hover/item:bg-[#df9c2c] group-hover/item:text-black transition-all"></i>
            <div class="flex flex-col">
              <span class="font-sans text-xs font-black text-white uppercase tracking-wider">ON-SIGHT DISINFECTION</span>
              <span class="font-sans text-[11px] text-gray-400 leading-normal mt-0.5">All bacteria sterilized and cleaned</span>
            </div>
          </div>

          <!-- Inclusion 5 -->
          <div class="flex items-start gap-3 group/item">
            <i class="ph-fill ph-wind text-xl text-[#df9c2c] bg-[#df9c2c]/10 p-2 rounded-sm group-hover/item:bg-[#df9c2c] group-hover/item:text-black transition-all"></i>
            <div class="flex flex-col">
              <span class="font-sans text-xs font-black text-white uppercase tracking-wider">CABIN FILTER CLEAN</span>
              <span class="font-sans text-[11px] text-gray-400 leading-normal mt-0.5">Dust & debris fully cleaned out</span>
            </div>
          </div>

          <!-- Inclusion 6 -->
          <div class="flex items-start gap-3 group/item">
            <i class="ph-fill ph-car text-xl text-[#df9c2c] bg-[#df9c2c]/10 p-2 rounded-sm group-hover/item:bg-[#df9c2c] group-hover/item:text-black transition-all"></i>
            <div class="flex flex-col">
              <span class="font-sans text-xs font-black text-white uppercase tracking-wider">BUFF & POLISH</span>
              <span class="font-sans text-[11px] text-gray-400 leading-normal mt-0.5">Pressure wash & hand towel dried</span>
            </div>
          </div>

          <!-- Inclusion 7 -->
          <div class="flex items-start gap-3 group/item">
            <i class="ph-fill ph-circle text-xl text-[#df9c2c] bg-[#df9c2c]/10 p-2 rounded-sm group-hover/item:bg-[#df9c2c] group-hover/item:text-black transition-all"></i>
            <div class="flex flex-col">
              <span class="font-sans text-xs font-black text-white uppercase tracking-wider">WHEEL WELL WASH</span>
              <span class="font-sans text-[11px] text-gray-400 leading-normal mt-0.5">Under-fender wells pressure washed</span>
            </div>
          </div>

          <!-- Inclusion 8 -->
          <div class="flex items-start gap-3 group/item">
            <i class="ph-fill ph-seal text-xl text-[#df9c2c] bg-[#df9c2c]/10 p-2 rounded-sm group-hover/item:bg-[#df9c2c] group-hover/item:text-black transition-all"></i>
            <div class="flex flex-col">
              <span class="font-sans text-xs font-black text-white uppercase tracking-wider">QUICK WAX APPLICATION</span>
              <span class="font-sans text-[11px] text-gray-400 leading-normal mt-0.5">High-gloss shine protection layer</span>
            </div>
          </div>

          <!-- Inclusion 9 -->
          <div class="flex items-start gap-3 group/item sm:col-span-2">
            <i class="ph-fill ph-sun text-xl text-[#df9c2c] bg-[#df9c2c]/10 p-2 rounded-sm group-hover/item:bg-[#df9c2c] group-hover/item:text-black transition-all"></i>
            <div class="flex flex-col">
              <span class="font-sans text-xs font-black text-white uppercase tracking-wider">TIRE SHINE & TRIM RESTORATION</span>
              <span class="font-sans text-[11px] text-gray-400 leading-normal mt-0.5">Applied to tires and plastic trim at end of wash for showroom look</span>
            </div>
          </div>

        </div>

        <!-- Booking CTA -->
        <a href="tel:3863073785" class="bg-[var(--color-brand-primary)] text-white text-center font-sans font-bold text-sm tracking-widest py-4 px-8 hover:bg-blue-600 transition-colors uppercase flex items-center justify-center gap-3 shadow-lg shadow-blue-900/40">
          <i class="ph-fill ph-phone-call text-lg"></i>
          CLAIM MAY SPECIAL: CALL (386) 307-3785
        </a>
      </div>

    </div>
  </div>
</section>
