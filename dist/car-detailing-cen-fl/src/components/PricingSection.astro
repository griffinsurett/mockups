---
---
<section class="w-full bg-black text-white py-24 px-8 md:px-16 border-b-[6px] border-[var(--color-brand-primary)]">
  <div class="max-w-7xl mx-auto flex flex-col items-center">
    
    <!-- Section Header -->
    <div class="flex flex-col items-center mb-20 text-center">
      <h2 class="font-serif text-3xl md:text-[42px] text-white font-bold leading-tight mb-6 drop-shadow-xl">
        PREMIUM PRICING PACKAGES
      </h2>
      <div class="w-12 h-1 bg-[var(--color-brand-primary)] shadow-[0_0_10px_rgba(28,117,188,0.5)]"></div>
    </div>

    <!-- Pricing Cards Container -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 w-full max-w-5xl mb-24">
      
      <!-- Sedan & Coupe Card -->
      <div class="bg-black border border-gray-900 overflow-hidden flex flex-col relative group transition-all duration-500 hover:border-gray-700 hover:shadow-2xl hover:shadow-[var(--color-brand-primary)]/10">
        <!-- Background subtle glow -->
        <div class="absolute inset-0 bg-gradient-to-b from-gray-900/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
        
        <!-- Card Header -->
        <div class="p-8 border-b border-gray-900 flex items-center justify-between relative z-10">
          <div class="flex items-center gap-4">
            <i class="ph-light ph-car text-4xl text-white"></i>
            <h3 class="font-sans text-lg font-extrabold tracking-widest uppercase text-white">SEDAN & COUPE</h3>
          </div>
        </div>
        
        <!-- Card Body -->
        <div class="p-8 flex-grow flex flex-col justify-between relative z-10">
          <div class="space-y-8 mb-12">
            <div class="flex justify-between items-center group/item cursor-default">
              <div class="flex items-center gap-4">
                <i class="ph-light ph-armchair text-2xl text-[var(--color-brand-primary)] opacity-80 group-hover/item:opacity-100 transition-opacity"></i>
                <span class="font-sans text-sm font-bold tracking-widest text-gray-300 group-hover/item:text-white transition-colors">INTERIOR DETAIL</span>
              </div>
              <span class="font-serif text-2xl text-white group-hover/item:text-[var(--color-brand-primary)] transition-colors">$140</span>
            </div>
            
            <div class="flex justify-between items-center group/item cursor-default">
              <div class="flex items-center gap-4">
                <i class="ph-light ph-drop text-2xl text-[var(--color-brand-primary)] opacity-80 group-hover/item:opacity-100 transition-opacity"></i>
                <span class="font-sans text-sm font-bold tracking-widest text-gray-300 group-hover/item:text-white transition-colors">EXTERIOR DETAIL</span>
              </div>
              <span class="font-serif text-2xl text-white group-hover/item:text-[var(--color-brand-primary)] transition-colors">$70</span>
            </div>
          </div>
          
          <!-- Most Popular Highlight -->
          <div class="relative bg-gradient-to-r from-[#01060d] via-[#0b3c66]/40 to-[#01060d] border border-[var(--color-brand-primary)] p-4 md:p-6 mt-auto">
            <div class="absolute -top-3 left-6 bg-[var(--color-brand-primary)] text-white text-[10px] font-extrabold px-3 py-1 uppercase tracking-widest shadow-lg">
              MOST POPULAR
            </div>
            <div class="flex justify-between items-center mt-2">
              <div class="flex items-center gap-2 md:gap-4">
                <i class="ph-fill ph-sparkle text-2xl md:text-3xl text-[var(--color-brand-primary)]"></i>
                <div class="flex flex-col">
                  <span class="font-sans text-sm md:text-base font-extrabold tracking-widest text-white uppercase">FULL DETAIL</span>
                  <span class="font-sans text-[10px] md:text-[11px] text-gray-300 uppercase tracking-widest font-bold">MAY SPECIAL &bull; INTERIOR + EXTERIOR</span>
                </div>
              </div>
              <span class="font-serif text-2xl md:text-4xl font-bold text-[#df9c2c]">$199.99</span>
            </div>
          </div>
        </div>
      </div>

      <!-- SUV & Truck Card -->
      <div class="bg-black border border-gray-900 overflow-hidden flex flex-col relative group transition-all duration-500 hover:border-gray-700 hover:shadow-2xl hover:shadow-[var(--color-brand-primary)]/10">
        <div class="absolute inset-0 bg-gradient-to-b from-gray-900/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
        
        <div class="p-8 border-b border-gray-900 flex items-center justify-between relative z-10">
          <div class="flex items-center gap-4">
            <i class="ph-light ph-jeep text-4xl text-white"></i>
            <h3 class="font-sans text-lg font-extrabold tracking-widest uppercase text-white">SUV & TRUCK</h3>
          </div>
        </div>
        
        <div class="p-8 flex-grow flex flex-col justify-between relative z-10">
          <div class="space-y-8 mb-12">
            <div class="flex justify-between items-center group/item cursor-default">
              <div class="flex items-center gap-4">
                <i class="ph-light ph-armchair text-2xl text-[var(--color-brand-primary)] opacity-80 group-hover/item:opacity-100 transition-opacity"></i>
                <span class="font-sans text-sm font-bold tracking-widest text-gray-300 group-hover/item:text-white transition-colors">INTERIOR DETAIL</span>
              </div>
              <span class="font-serif text-2xl text-white group-hover/item:text-[var(--color-brand-primary)] transition-colors">$165</span>
            </div>
            
            <div class="flex justify-between items-center group/item cursor-default">
              <div class="flex items-center gap-4">
                <i class="ph-light ph-drop text-2xl text-[var(--color-brand-primary)] opacity-80 group-hover/item:opacity-100 transition-opacity"></i>
                <span class="font-sans text-sm font-bold tracking-widest text-gray-300 group-hover/item:text-white transition-colors">EXTERIOR DETAIL</span>
              </div>
              <span class="font-serif text-2xl text-white group-hover/item:text-[var(--color-brand-primary)] transition-colors">$75</span>
            </div>
          </div>
          
          <div class="relative bg-gradient-to-r from-gray-900 via-gray-800/40 to-gray-900 border border-gray-700 p-4 md:p-6 mt-auto transition-colors duration-500 group-hover:border-gray-500">
            <div class="flex justify-between items-center mt-2">
              <div class="flex items-center gap-2 md:gap-4">
                <i class="ph-fill ph-sparkle text-2xl md:text-3xl text-[#df9c2c] transition-colors"></i>
                <div class="flex flex-col">
                  <span class="font-sans text-sm md:text-base font-extrabold tracking-widest text-white uppercase">FULL DETAIL</span>
                  <span class="font-sans text-[10px] md:text-[11px] text-gray-300 uppercase tracking-widest font-bold">MAY SPECIAL &bull; INTERIOR + EXTERIOR</span>
                </div>
              </div>
              <span class="font-serif text-2xl md:text-4xl font-bold text-[#df9c2c]">$199.99</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Add-Ons Section -->
    <div class="w-full max-w-5xl mb-16">
      <h3 class="font-serif text-2xl text-white font-bold mb-8 text-center drop-shadow-md">POPULAR ADD-ONS</h3>
      
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <!-- Addon Card -->
        <div class="bg-black border border-gray-900 p-8 flex flex-col items-center text-center group hover:bg-gray-900 hover:border-gray-700 transition-all duration-300">
          <i class="ph-light ph-engine text-4xl mb-4 text-[var(--color-brand-primary)] group-hover:scale-110 transition-transform duration-300"></i>
          <span class="font-sans text-[11px] font-extrabold tracking-widest text-gray-300 uppercase mb-2">ENGINE BAY</span>
          <span class="font-serif text-xl text-white">$75</span>
        </div>
        
        <div class="bg-black border border-gray-900 p-8 flex flex-col items-center text-center group hover:bg-gray-900 hover:border-gray-700 transition-all duration-300">
          <i class="ph-light ph-paw-print text-4xl mb-4 text-[var(--color-brand-primary)] group-hover:scale-110 transition-transform duration-300"></i>
          <span class="font-sans text-[11px] font-extrabold tracking-widest text-gray-300 uppercase mb-2">DOG HAIR</span>
          <span class="font-serif text-xl text-white">$50</span>
        </div>
        
        <div class="bg-black border border-gray-900 p-8 flex flex-col items-center text-center group hover:bg-gray-900 hover:border-gray-700 transition-all duration-300">
          <i class="ph-light ph-wind text-4xl mb-4 text-[var(--color-brand-primary)] group-hover:scale-110 transition-transform duration-300"></i>
          <span class="font-sans text-[11px] font-extrabold tracking-widest text-gray-300 uppercase mb-2">ODOR REMOVAL</span>
          <span class="font-serif text-xl text-white">$125</span>
        </div>
        
        <div class="bg-black border border-gray-900 p-8 flex flex-col items-center text-center group hover:bg-gray-900 hover:border-gray-700 transition-all duration-300">
          <i class="ph-light ph-car-profile text-4xl mb-4 text-[var(--color-brand-primary)] group-hover:scale-110 transition-transform duration-300"></i>
          <span class="font-sans text-[11px] font-extrabold tracking-widest text-gray-300 uppercase mb-2">3RD ROW</span>
          <span class="font-serif text-xl text-white">+ $25</span>
        </div>
      </div>
      
      <p class="text-center text-sm font-sans text-gray-500 italic mt-8">Prices vary based on the condition of the vehicle.</p>
    </div>

    <!-- Mobile Service Button -->
    <a href="#" class="inline-flex items-center gap-3 bg-[var(--color-brand-primary)] text-white py-4 px-10 hover:bg-blue-600 transition-colors shadow-lg shadow-blue-900/50">
      <i class="ph-fill ph-map-pin text-xl"></i>
      <span class="font-sans text-sm font-bold tracking-widest uppercase">MOBILE SERVICE AVAILABLE</span>
    </a>

  </div>
</section>
