---
---
<section class="w-full bg-[#050811] grid grid-cols-1 lg:grid-cols-2 border-t border-gray-950 overflow-hidden relative">
  
  <!-- Left Column: Emotional Brand Copy on deep navy/black shield (z-20) -->
  <div class="relative z-20 flex items-center bg-[#050811] py-20 px-8 sm:py-24 sm:px-16 lg:py-32 lg:pl-24 lg:pr-16">
    <div class="max-w-xl">
      <!-- Special Ad Subtitle -->
      <span class="font-sans text-xs font-black tracking-[0.3em] text-[var(--color-brand-primary)] uppercase mb-4 block">RESTORING LEGENDS</span>
      
      <!-- Kevin's Ad Header Copy -->
      <h2 class="font-serif text-3xl md:text-[38px] text-white font-bold leading-tight mb-6 drop-shadow-xl">
        Restore your cherished vehicle to its original, factory-fresh glory.
      </h2>
      
      <!-- Small blue separator line -->
      <div class="w-12 h-1 bg-[var(--color-brand-primary)] mb-8 shadow-[0_0_10px_rgba(28,117,188,0.5)]"></div>

      <!-- Kevin's Ad Subheading Copy -->
      <p class="font-serif text-lg md:text-xl text-[#df9c2c] italic mb-10 leading-relaxed">
        "Restoring Legends, One Detail at a Time."
      </p>

      <!-- Bottom Pillars (Precision & Expert) -->
      <div class="space-y-6 mb-12">
        <div class="flex items-start gap-4">
          <i class="ph-fill ph-bullseye text-2xl text-[var(--color-brand-primary)]"></i>
          <div>
            <h4 class="font-sans text-sm font-black text-white uppercase tracking-wider">PRECISION DETAILING</h4>
            <p class="font-sans text-xs text-gray-400 mt-1 leading-relaxed">Micro-focused care that steam cleans, sterilizes, and restores every stitch and panel gap.</p>
          </div>
        </div>
        
        <div class="flex items-start gap-4">
          <i class="ph-fill ph-shield-check text-2xl text-[var(--color-brand-primary)]"></i>
          <div>
            <h4 class="font-sans text-sm font-black text-white uppercase tracking-wider">EXPERT CRAFTSMANSHIP</h4>
            <p class="font-sans text-xs text-gray-400 mt-1 leading-relaxed">Dedicated to top-quality trust, delivering mirror-like paint correction and factory-fresh cabins.</p>
          </div>
        </div>
      </div>
      
      <!-- Primary Action -->
      <a href="tel:3863073785" class="inline-block bg-[var(--color-brand-primary)] text-white font-sans font-bold text-xs tracking-widest py-4 px-10 rounded-sm hover:bg-blue-600 transition-colors uppercase shadow-lg shadow-blue-900/40">
        SCHEDULE YOUR RESTORATION
      </a>
    </div>
  </div>

  <!-- Right Column: Meticulously overlapping Corvette C8 image representing the ad exactly -->
  <div class="w-full h-[320px] sm:h-[450px] lg:h-auto min-h-full relative overflow-hidden -mt-[2px] lg:mt-0 lg:-ml-[2px] z-10 bg-[#cfdbe8] flex items-center justify-center">
    <img src="/assets/images/legends.png" alt="Restoring Legends Corvette C8" class="w-full h-full object-cover object-center lg:absolute lg:inset-0 scale-[1.05] group-hover:scale-110 transition-transform duration-700" />
    
    <!-- Smooth cinematic fading overlays to blend the pastels back into the dark side (Ultra-narrow blend for 100% Corvette visibility) -->
    <div class="absolute inset-0 bg-gradient-to-b from-[#050811] via-transparent to-transparent lg:bg-gradient-to-r lg:from-[#050811] lg:via-[#050811]/15 lg:via-[12%] lg:to-transparent lg:to-[30%] pointer-events-none z-10"></div>
  </div>

</section>
