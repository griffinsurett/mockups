---
import "../../styles/global.css";

interface Props {
  title?: string;
}
const { title = "All Star Window Cleaning" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body class="overflow-x-hidden bg-white" style="font-family: 'Segoe UI', Arial, sans-serif;">

    <header id="site-header" class="sticky top-0 z-50">

      <!-- ── Desktop top bar ── -->
      <div class="hidden md:grid grid-cols-[1fr_auto_1fr] items-center gap-4 px-8 py-3.5 w-full bg-[#111] text-white">

        <!-- Left: rating + serving -->
        <div class="flex flex-col gap-6">
          <div class="flex items-center gap-2.5">
            <svg width="24" height="24" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" class="shrink-0">
              <path fill="#4285F4" d="M44.5 20H24v8.5h11.8C34.7 33.9 30.1 37 24 37c-7.2 0-13-5.8-13-13s5.8-13 13-13c3.1 0 5.9 1.1 8.1 2.9l6.4-6.4C34.6 5.1 29.6 3 24 3 12.4 3 3 12.4 3 24s9.4 21 21 21c10.5 0 20-7.8 20-21 0-1.4-.2-2.7-.5-4z"/>
              <path fill="#34A853" d="M6.3 14.7l7 5.1C15 16.1 19.2 13 24 13c3.1 0 5.9 1.1 8.1 2.9l6.4-6.4C34.6 5.1 29.6 3 24 3c-7.7 0-14.3 4.4-17.7 11.7z"/>
              <path fill="#FBBC05" d="M24 45c5.5 0 10.5-1.9 14.4-5.1l-6.7-5.5C29.6 36 26.9 37 24 37c-6 0-11.1-4-12.9-9.5l-7 5.4C7.6 40.5 15.2 45 24 45z"/>
              <path fill="#EA4335" d="M44.5 20H24v8.5h11.8c-1 3-3.3 5.4-6.3 7l6.7 5.5C40.3 37.6 45 31.5 45 24c0-1.4-.2-2.7-.5-4z"/>
            </svg>
            <div>
              <div class="aswc-rating-stars text-base leading-none">★★★★★</div>
              <div class="text-[0.78rem] font-semibold text-white/85 mt-0.5">Rated 5 Stars on Google</div>
            </div>
          </div>
          <div class="text-[0.78rem] uppercase tracking-[0.04em] text-[#dcfb19]">
            Serving
            <strong class="block text-base text-white normal-case tracking-normal font-bold">Central NJ</strong>
          </div>
        </div>

        <!-- Center: logo -->
        <div class="flex justify-center items-center">
          <img src="/all-star-window-cleaning/logo.png" alt="All Star Window Cleaning" id="desktop-logo" class="w-auto object-contain" />
        </div>

        <!-- Right: CTA + phone -->
        <div class="flex flex-col items-end gap-7">
          <a href="#contact" class="bg-[#974ff5] hover:bg-[#7d38d4] text-white font-bold text-[0.95rem] px-6 py-2.5 rounded tracking-wide transition-colors duration-200">
            Request Service
          </a>
          <div class="text-right leading-snug">
            <div class="text-[0.78rem] uppercase tracking-[0.04em] text-[#dcfb19]">Call Us Today</div>
            <a href="tel:7325550192" class="text-[1.45rem] font-extrabold text-white tracking-tight">(732) 555-0192</a>
          </div>
        </div>

      </div>

      <!-- ── Mobile top bar ── -->
      <div class="relative flex md:hidden flex-col gap-2 px-5 pt-2 pb-4 w-full bg-[#111] text-white">

        <!-- Hamburger absolute top-right -->
        <button class="absolute top-3 right-4 flex flex-col justify-center items-center gap-1.5 p-2 bg-transparent border-0" aria-label="Open menu">
          <span class="block w-6 rounded" style="height:2px; background:#dcfb19"></span>
          <span class="block w-6 rounded" style="height:2px; background:#dcfb19"></span>
          <span class="block w-6 rounded" style="height:2px; background:#dcfb19"></span>
        </button>

        <!-- Logo centered -->
        <div class="flex justify-center">
          <img src="/all-star-window-cleaning/logo.png" alt="All Star Window Cleaning" id="mobile-logo" class="w-auto object-contain" />
        </div>

        <!-- CTA + phone -->
        <div class="flex flex-col gap-3 pb-2">
          <a href="#contact" class="w-full text-center bg-[#974ff5] hover:bg-[#7d38d4] text-white font-bold text-base py-3 rounded-md tracking-wide transition-colors duration-200">
            Request Service
          </a>
          <div class="text-center">
            <div class="text-[0.78rem] uppercase tracking-[0.04em] text-[#dcfb19]">Call Us Today</div>
            <a href="tel:7325550192" class="text-[1.45rem] font-extrabold text-white tracking-tight">(732) 555-0192</a>
          </div>
        </div>

      </div>

      <!-- ── Nav (desktop only) ── -->
      <nav class="hidden md:flex items-center justify-center gap-1 px-8 bg-white border-b-2 border-[#e5e5e5]">
        <a href="/all-star-window-cleaning" class="aswc-nav-link active">Home</a>
        <a href="#" class="aswc-nav-link">Window Cleaning Services</a>
        <a href="#" class="aswc-nav-link">Gallery</a>
        <a href="#" class="aswc-nav-link">About <span class="text-[0.7rem] opacity-50">▼</span></a>
        <a href="#" class="aswc-nav-link">Contact <span class="text-[0.7rem] opacity-50">▼</span></a>
      </nav>

    </header>

    <slot />

  </body>

  <style>
    #desktop-logo {
      height: 10rem;
      transition: height 400ms ease;
    }
    #site-header[data-compact="true"] #desktop-logo {
      height: 7rem;
    }

    #mobile-logo {
      height: 9rem;
      transition: height 400ms ease;
    }
    #site-header[data-compact="true"] #mobile-logo {
      height: 5rem;
    }

    @media (prefers-reduced-motion: reduce) {
      #desktop-logo, #mobile-logo { transition: none; }
    }
  </style>

  <script>
    (function () {
      const header = document.getElementById("site-header");
      if (!header) return;

      let ticking = false;

      const update = () => {
        if (window.scrollY > 40) {
          header.setAttribute("data-compact", "true");
        } else {
          header.removeAttribute("data-compact");
        }
        ticking = false;
      };

      window.addEventListener("scroll", () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(update);
      }, { passive: true });

      update();
    })();
  </script>

</html>
