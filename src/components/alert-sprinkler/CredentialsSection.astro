---
const credentials = [
  {
    icon: "verified_user",
    title: "Licensed in NJ",
    body: "Fully state-licensed for fire protection services and system engineering.",
  },
  {
    icon: "security",
    title: "Fully Insured",
    body: "General liability and workers' compensation coverage for all industrial worksites.",
  },
  {
    icon: "workspace_premium",
    title: "NFPA Member",
    body: "Committed to the highest standards of the National Fire Protection Association.",
  },
];
---

<section class="w-full py-24 px-6 md:px-16" style="background: #fff8f7;">
  <div class="max-w-7xl mx-auto">

    <div class="flex flex-col md:flex-row justify-between items-end mb-14 gap-8">
      <div class="max-w-xl">
        <span class="as-label-caps text-as-primary mb-2 block">OUR CREDENTIALS</span>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight" style="color: #291715;">
          Licensed, Certified &amp; Fully Insured
        </h2>
        <p class="text-base leading-relaxed mt-4" style="color: #5d3f3b;">
          We maintain the highest levels of certification and professional insurance to give you peace of mind.
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {credentials.map((c) => (
        <div class="bg-white p-8 border border-as-border flex flex-col items-center text-center">
          <div
            class="w-20 h-20 rounded-full flex items-center justify-center mb-6"
            style="background: #ffe9e6;"
          >
            <span
              class="material-symbols-outlined text-as-primary text-4xl"
              style="font-variation-settings: 'FILL' 0;"
            >{c.icon}</span>
          </div>
          <h3 class="font-bold text-xl mb-2" style="color: #291715;">{c.title}</h3>
          <p class="text-sm leading-relaxed" style="color: #5d3f3b;">{c.body}</p>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
  }
</style>
