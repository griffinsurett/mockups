---
const checks = [
  {
    title: "Annual & Quarterly Inspections",
    body: "Comprehensive checks of valves, pipes, and sprinkler heads per NFPA 25 schedules.",
  },
  {
    title: "Main Drain & Water Flow Tests",
    body: "Verification of adequate water supply and alarm functionality.",
  },
  {
    title: "Deficiency Corrections",
    body: "Rapid repair of any items found during the inspection process.",
  },
];
---

<section class="w-full py-24 px-6 md:px-16" style="background: #F8FAFC;">
  <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">

    <!-- Left: content -->
    <div>
      <span class="as-label-caps text-as-primary mb-2 block">VIGILANCE &amp; COMPLIANCE</span>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-6" style="color: #291715;">
        NFPA 25 Inspection &amp; Testing
      </h2>
      <p class="text-base md:text-lg leading-relaxed mb-8" style="color: #5d3f3b;">
        Stay compliant and protected with our rigorous inspection protocols. We ensure your system meets
        all local fire codes and NFPA standards, providing detailed documentation for fire marshals and
        insurance providers.
      </p>

      <ul class="flex flex-col gap-6 mb-10">
        {checks.map((c) => (
          <li class="flex items-start gap-4">
            <span class="material-symbols-outlined text-as-primary mt-0.5 shrink-0" style="font-variation-settings: 'FILL' 0;">task_alt</span>
            <div>
              <span class="font-bold text-sm block" style="color: #291715;">{c.title}</span>
              <span class="text-sm leading-snug" style="color: #5d3f3b;">{c.body}</span>
            </div>
          </li>
        ))}
      </ul>

      <a href="/alert-sprinkler/contact" class="as-btn-primary inline-block text-base px-8 py-4">
        Schedule an Inspection
      </a>
    </div>

    <!-- Right: image + stat callout -->
    <div class="relative">
      <!-- Logo overlay top-right -->
      <img
        src="/alert-sprinkler/alert-logo.png"
        alt=""
        aria-hidden="true"
        class="hidden lg:block absolute -top-16 -right-12 z-10 w-44 pointer-events-none"
      />

      <div class="aspect-square overflow-hidden border border-as-border" style="border-radius: 0.25rem;">
        <img
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuAaBsZ8KP8agvAtmGrY0n20wVEZ77rC_1jL6iY3FgIesxT97sirkIgflr420yT8DWbSIadTcUniCqhyu0YUq8RlgFfKLP3DBlR5iDQUvGgiMoyQ5Oe1LXJtEmNF5duKhN2Wdd48EU8UMPGewrwtMsbOeeo4MgpO-kxYNY_M3WR_sSEFfVaBJhxJG6D9nyVsD3c5_nSzwmABwLccO05NvPOs0ibqmy3zkIXMgX1hHEaHe5se87BglB4-8D7C1i4EwyR2GUSPGgoTNpM"
          alt="Fire protection engineer inspecting system"
          class="w-full h-full object-cover"
          loading="lazy"
        />
      </div>
      <!-- Floating stat card -->
      <div
        class="absolute -bottom-8 -left-8 bg-white p-8 border border-as-border shadow-sm max-w-[240px]"
        style="border-radius: 0.25rem;"
      >
        <span class="font-extrabold block mb-1 text-as-primary" style="font-size: 56px; line-height: 1; letter-spacing: -0.02em;">45+</span>
        <span class="as-label-caps" style="color: #5d3f3b;">Years of Continuous NJ Safety Service</span>
      </div>
    </div>

  </div>
</section>

<style>
  .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
  }
</style>
