---
const year = new Date().getFullYear();
---

<footer>
  <!-- CTA strip — red → dark gradient -->
  <div style="background: linear-gradient(180deg, #760202 0%, #1a0302 100%);">
    <div class="max-w-7xl mx-auto px-6 md:px-16 py-14 lg:py-20 text-center">
      <h2 class="font-extrabold text-2xl lg:text-3xl text-white uppercase tracking-tight">
        Ready to Secure Your Facility?
      </h2>
      <p class="text-white/75 text-base mt-4 mb-8 max-w-xl mx-auto">
        Our technical specialists are available to review your blueprints or perform a site inspection today.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="/alert-sprinkler/contact" class="as-btn-primary inline-flex items-center justify-center px-10 h-[50px] text-base">
          Request a Quote
        </a>
        <div class="text-center">
          <div class="as-label-caps" style="color: rgba(255,255,255,0.65);">24/7 Emergency Response</div>
          <a href="tel:7325211666" class="font-extrabold text-white text-2xl tracking-tight">732-521-1666</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Dark footer bottom -->
  <div style="background: #140302; margin-top: -1px;">
    <div class="max-w-7xl mx-auto px-6 md:px-16 pt-14 pb-8">

      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 pb-10 border-b border-white/10">

        <!-- Brand col -->
        <div class="flex flex-col gap-4">
          <div class="font-extrabold tracking-tighter text-lg text-white uppercase">Alert Sprinkler Co., Inc.</div>
          <p class="text-white/55 text-sm leading-relaxed">
            Leading the fire protection industry since 1977. Precision engineering, reliable service, and 24/7 protection for what matters most.
          </p>
        </div>

        <!-- Contact col -->
        <div class="flex flex-col gap-4">
          <h4 class="as-label-caps text-white">CONTACT US</h4>
          <ul class="flex flex-col gap-3 text-sm text-white/55">
            <li class="flex items-start gap-2">
              <span class="material-symbols-outlined text-as-primary text-base mt-0.5 shrink-0">location_on</span>
              1085 Cranbury South River Rd., Suite 1, Jamesburg, NJ 08331
            </li>
            <li class="flex items-center gap-2">
              <span class="material-symbols-outlined text-as-primary text-base shrink-0">call</span>
              <a href="tel:7325211666" class="hover:text-white transition-colors">732-521-1666</a>
            </li>
            <li class="flex items-center gap-2">
              <span class="material-symbols-outlined text-as-primary text-base shrink-0">fax</span>
              Fax: 732-521-2618
            </li>
          </ul>
        </div>

        <!-- Quick links col -->
        <div class="flex flex-col gap-4">
          <h4 class="as-label-caps text-white">QUICK LINKS</h4>
          <ul class="flex flex-col gap-2 text-sm">
            <li><a href="#" class="text-white/55 hover:text-white transition-colors">Commercial Solutions</a></li>
            <li><a href="#" class="text-white/55 hover:text-white transition-colors">Industrial Protection</a></li>
            <li><a href="#" class="text-white/55 hover:text-white transition-colors">Inspection Scheduling</a></li>
            <li><a href="#" class="text-white/55 hover:text-white transition-colors">Service Area Map</a></li>
            <li><a href="#" class="text-white/55 hover:text-white transition-colors">NFPA 25 Compliance</a></li>
          </ul>
        </div>

      </div>

      <div class="mt-6 flex flex-col md:flex-row justify-between items-center gap-3 text-sm text-white/40">
        <div class="flex flex-wrap gap-4 justify-center md:justify-start">
          <a href="#" class="hover:text-white transition-colors">Privacy Policy</a>
          <span class="text-white/20">·</span>
          <a href="#" class="hover:text-white transition-colors">Terms of Service</a>
          <span class="text-white/20">·</span>
          <a href="#" class="hover:text-white transition-colors">Accessibility</a>
        </div>
        <div class="flex flex-col md:flex-row items-center gap-2">
          <span>&copy;{year} Alert Sprinkler Co., Inc. Licensed &amp; Fully Insured.</span>
          <a href="https://griffinswebservices.com" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">
            Built By Griffin's Web Services
          </a>
        </div>
      </div>

    </div>
  </div>
</footer>

<style>
  .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
  }
</style>
