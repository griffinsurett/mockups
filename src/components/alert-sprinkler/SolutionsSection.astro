<section id="solutions" class="w-full py-24 px-6 md:px-16" style="background: #fff8f7;">
  <div class="max-w-7xl mx-auto">

    <!-- Header -->
    <div class="flex flex-col items-center text-center mb-14">
      <span class="as-label-caps text-as-primary mb-2">OUR EXPERTISE</span>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight" style="color: #291715;">
        Comprehensive Fire Protection Solutions
      </h2>
    </div>

    <!-- Bento grid: 1 large left + 3 stacked right -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:h-[600px]">

      <!-- Commercial (featured large) -->
      <a
        href="/alert-sprinkler/contact"
        class="md:col-span-8 group relative overflow-hidden bg-gray-100 border border-as-border flex flex-col justify-end min-h-[360px] md:min-h-0"
      >
        <img
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuBtVsyOlCJk3k4-NczC6Pbm-4_7Fbu5R4RSjFjYl0NcNKLEv6cL6OBoyn6DJ7C1KxjarE-sgAWzbU47jcA6AxtX_dBR_rdY5Z_GR6eHUCK9ToOGynv_XkWmRibYdP63pMZqdL4bY8V_eMsw5CsrnTrHwHuTRbX0Mr3O3ZSO0vLLMPXgH2TyDCZrjm3CQdEDDzpny2KUBtYCG4jZJjt3KtkZAY4jUoCBG7E0qsgjwEVamF46mvbsVC3b62HcDbF9hVUjbV5KPBxRIOM"
          alt="Commercial Fire Protection"
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
        />
        <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(0,0,0,0.88) 0%, rgba(0,0,0,0.45) 60%, rgba(0,0,0,0.25) 100%);"></div>
        <div class="relative z-10 p-8">
          <h3 class="text-3xl md:text-4xl font-bold tracking-tight text-white mb-3">Commercial</h3>
          <p class="text-white/75 text-sm leading-relaxed max-w-md">
            Complete systems for high-rises, retail centers, and professional offices compliant with all local fire codes.
          </p>
          <span class="inline-flex items-center gap-2 mt-6 as-label-caps text-as-primary group-hover:gap-4 transition-all duration-300">
            Request Inspection →
          </span>
        </div>
      </a>

      <!-- 3 smaller cards -->
      {secondary.map((s) => (
        <a
          href="/alert-sprinkler/contact"
          class="md:col-span-4 group relative overflow-hidden bg-gray-100 border border-as-border flex flex-col justify-end min-h-[160px]"
        >
          <img
            src={s.img}
            alt={s.title}
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
          />
          <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(0,0,0,0.88) 0%, rgba(0,0,0,0.45) 100%);"></div>
          <div class="relative z-10 p-6">
            <h3 class="text-xl font-bold tracking-tight text-white mb-1">{s.title}</h3>
            <p class="text-white/65 text-xs leading-snug">{s.body}</p>
          </div>
        </a>
      ))}

    </div>
  </div>
</section>

<style>
  .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
  }
</style>
