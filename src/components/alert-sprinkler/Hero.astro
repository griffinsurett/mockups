---
import BackgroundMedia from "./BackgroundMedia.astro";
---

<section class="relative w-full overflow-hidden flex flex-col" style="height: 100dvh;">
  <!-- Video background -->
  <BackgroundMedia
    backgroundMedia={{
      video: {
        src: "/alert-sprinkler/hero-video.mp4",
        autoPlay: true,
        muted: true,
        loop: true,
        playsInline: true,
        preload: "auto",
      },
    }}
  />

  <!-- Dark gradient overlay -->
  <div
    class="absolute inset-0 z-0"
    style="background: linear-gradient(to bottom, rgba(20,8,7,0.55) 0%, rgba(20,8,7,0.65) 60%, rgba(20,8,7,0.85) 100%);"
    aria-hidden="true"
  ></div>

  <!-- Hero content -->
  <div class="relative z-10 flex flex-col items-center justify-center text-center flex-1 px-6 md:px-16">
    <!-- Large logo in-flow at top of hero -->
    <a href="/alert-sprinkler" class="mb-6 shrink-0">
      <img
        src="/alert-sprinkler/alert-logo.png"
        alt="Alert Sprinkler Co., Inc."
        class="object-contain drop-shadow-xl"
        style="width: clamp(12rem, 24vw, 20rem);"
        loading="eager"
      />
    </a>
    <!-- Eyebrow -->
    <span class="as-label-caps text-white/60 mb-4 block">Established 1977</span>

    <!-- Company name as hero headline -->
    <h1
      class="text-white font-extrabold tracking-tighter leading-none mb-6"
      style="font-size: clamp(21px, 3.5vw, 48px); letter-spacing: -0.03em;"
    >
      Alert Sprinkler Co., Inc.
    </h1>

    <!-- Tagline -->
    <p class="text-white/80 text-base md:text-lg max-w-2xl mb-10 leading-relaxed">
      Fire Sprinkler Engineering, Installation, Inspection,<br class="hidden md:block" />
      Maintenance &amp; Repair — New Jersey &amp; Pennsylvania
    </p>

    <!-- CTAs -->
    <div class="flex flex-wrap gap-4 justify-center">
      <a href="/alert-sprinkler/contact" class="as-btn-primary text-base px-8 py-4">
        Request Inspection
      </a>
      <a href="#solutions" class="as-btn-outline text-base px-8 py-4">
        Our Capabilities
      </a>
    </div>

    <!-- Social proof row -->
    <div class="mt-6 flex items-center gap-2">
      <svg width="20" height="20" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" class="shrink-0">
        <path fill="#4285F4" d="M44.5 20H24v8.5h11.8C34.7 33.9 30.1 37 24 37c-7.2 0-13-5.8-13-13s5.8-13 13-13c3.1 0 5.9 1.1 8.1 2.9l6.4-6.4C34.6 5.1 29.6 3 24 3 12.4 3 3 12.4 3 24s9.4 21 21 21c10.5 0 20-7.8 20-21 0-1.4-.2-2.7-.5-4z"/>
        <path fill="#34A853" d="M6.3 14.7l7 5.1C15 16.1 19.2 13 24 13c3.1 0 5.9 1.1 8.1 2.9l6.4-6.4C34.6 5.1 29.6 3 24 3c-7.7 0-14.3 4.4-17.7 11.7z"/>
        <path fill="#FBBC05" d="M24 45c5.5 0 10.5-1.9 14.4-5.1l-6.7-5.5C29.6 36 26.9 37 24 37c-6 0-11.1-4-12.9-9.5l-7 5.4C7.6 40.5 15.2 45 24 45z"/>
        <path fill="#EA4335" d="M44.5 20H24v8.5h11.8c-1 3-3.3 5.4-6.3 7l6.7 5.5C40.3 37.6 45 31.5 45 24c0-1.4-.2-2.7-.5-4z"/>
      </svg>
      <span style="color: #FBBC05; font-size: 0.9rem; letter-spacing: 0.04em;">★★★★★</span>
      <span class="text-white/90 text-sm font-bold">5.0</span>
      <span class="text-white/30 text-sm">·</span>
      <span class="text-white/70 text-sm font-semibold">178+ Reviews</span>
    </div>
  </div>

  <!-- Trust bar marquee pinned to bottom of hero -->
  <div class="relative z-10 w-full overflow-hidden" style="background: rgba(0,0,0,0.5); backdrop-filter: blur(4px);">
    <div class="as-marquee-track flex items-center py-5 gap-12" aria-hidden="true">
      <!-- Set 1 -->
      <span class="as-marquee-item shrink-0">CODE COMPLIANCE</span>
      <span class="as-marquee-dot shrink-0">·</span>
      <span class="as-marquee-item shrink-0">EXPERT ENGINEERING</span>
      <span class="as-marquee-dot shrink-0">·</span>
      <span class="as-marquee-item shrink-0">24/7 EMERGENCY</span>
      <span class="as-marquee-dot shrink-0">·</span>
      <span class="as-marquee-item shrink-0">FULLY INSURED</span>
      <span class="as-marquee-dot shrink-0">·</span>
      <span class="as-marquee-item shrink-0">LICENSED &amp; INSURED</span>
      <span class="as-marquee-dot shrink-0">·</span>
      <span class="as-marquee-item shrink-0">FIRE PROTECTION SPECIALISTS</span>
      <span class="as-marquee-dot shrink-0">·</span>
      <span class="as-marquee-item shrink-0">ESTABLISHED 1977</span>
      <span class="as-marquee-dot shrink-0">·</span>
      <span class="as-marquee-item shrink-0">NJ &amp; PA SERVICE AREA</span>
      <span class="as-marquee-dot shrink-0">·</span>
      <!-- Set 2 (duplicate for seamless loop) -->
      <span class="as-marquee-item shrink-0">CODE COMPLIANCE</span>
      <span class="as-marquee-dot shrink-0">·</span>
      <span class="as-marquee-item shrink-0">EXPERT ENGINEERING</span>
      <span class="as-marquee-dot shrink-0">·</span>
      <span class="as-marquee-item shrink-0">24/7 EMERGENCY</span>
      <span class="as-marquee-dot shrink-0">·</span>
      <span class="as-marquee-item shrink-0">FULLY INSURED</span>
      <span class="as-marquee-dot shrink-0">·</span>
      <span class="as-marquee-item shrink-0">LICENSED &amp; INSURED</span>
      <span class="as-marquee-dot shrink-0">·</span>
      <span class="as-marquee-item shrink-0">FIRE PROTECTION SPECIALISTS</span>
      <span class="as-marquee-dot shrink-0">·</span>
      <span class="as-marquee-item shrink-0">ESTABLISHED 1977</span>
      <span class="as-marquee-dot shrink-0">·</span>
      <span class="as-marquee-item shrink-0">NJ &amp; PA SERVICE AREA</span>
      <span class="as-marquee-dot shrink-0">·</span>
    </div>
  </div>
</section>

<style>
  .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
  }

  .as-marquee-item {
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.85);
    white-space: nowrap;
  }

  .as-marquee-dot {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.25);
  }

  .as-marquee-track {
    width: max-content;
    animation: as-marquee 30s linear infinite;
  }

  @keyframes as-marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .as-marquee-track { animation: none; }
  }
</style>
