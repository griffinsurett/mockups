<section class="w-full py-24 px-6 md:px-16" style="background: #F8FAFC;">
  <div class="max-w-7xl mx-auto">

    <div class="flex flex-col items-center text-center mb-14">
      <span class="as-label-caps text-as-primary mb-2">WHO WE SERVE</span>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight" style="color: #291715;">
        Sectors We Protect
      </h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {sectors.map((s) => (
        <a
          href="/alert-sprinkler/contact"
          class="group relative overflow-hidden flex flex-col justify-end border border-as-border"
          style="min-height: 320px; border-radius: 0.25rem;"
        >
          <img
            src={s.img}
            alt={s.title}
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
          />
          <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(20,3,2,0.92) 0%, rgba(20,3,2,0.4) 60%, rgba(20,3,2,0.1) 100%);"></div>
          <div class="relative z-10 p-6">
            <h3 class="text-xl font-extrabold tracking-tight text-white mb-2">{s.title}</h3>
            <p class="text-white/65 text-xs leading-snug">{s.body}</p>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>
