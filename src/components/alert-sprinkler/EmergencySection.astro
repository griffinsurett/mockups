<section class="w-full py-24 px-6 md:px-16" style="background: #760202; color: #fff;">
  <div class="max-w-7xl mx-auto text-center">

    <span class="material-symbols-outlined text-6xl mb-6 block" style="font-variation-settings: 'FILL' 1;">emergency_home</span>

    <h2 class="font-extrabold tracking-tighter mb-6" style="font-size: clamp(36px, 5vw, 56px); line-height: 1.1; letter-spacing: -0.02em;">
      24/7 Emergency Repairs
    </h2>

    <p class="text-base md:text-lg mb-10 max-w-2xl mx-auto" style="opacity: 0.9; line-height: 1.75;">
      A leak or system failure can't wait. Our rapid-response teams are on standby 24 hours a day,
      365 days a year to keep your facility protected.
    </p>

    <div
      class="inline-flex flex-col md:flex-row items-center gap-8 p-6"
      style="background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.2); border-radius: 0.5rem; backdrop-filter: blur(4px);"
    >
      <div class="flex flex-col items-center md:items-start">
        <span class="as-label-caps" style="opacity: 0.75;">IMMEDIATE ASSISTANCE</span>
        <a href="tel:7325211666" class="font-extrabold tracking-tight text-white hover:opacity-80 transition-opacity" style="font-size: clamp(28px, 4vw, 40px);">
          732-521-1666
        </a>
      </div>
      <div class="h-10 w-px hidden md:block" style="background: rgba(255,255,255,0.2);"></div>
      <a
        href="/alert-sprinkler/contact"
        class="bg-white text-as-primary font-bold as-label-caps px-10 py-5 hover:opacity-90 transition-all active:scale-95"
        style="color: #760202;"
      >
        Dispatch Technician Now
      </a>
    </div>

  </div>
</section>

<style>
  .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
  }
</style>
