---
const testimonials = [
  {
    name: "Robert M.",
    text: "Alert Sprinkler has been servicing our commercial building for over 10 years. Always on time, thorough, and their documentation is perfect for our insurance audits.",
  },
  {
    name: "Linda K.",
    text: "When we had an emergency leak at 2am, their team was on-site within the hour. Truly 24/7 service — couldn't be more grateful.",
  },
  {
    name: "Thomas A.",
    text: "Professional, knowledgeable, and honest. They found deficiencies two other companies missed and fixed everything at a fair price.",
  },
  {
    name: "Susan R.",
    text: "We've used Alert Sprinkler for NFPA 25 inspections across all our NJ properties. Reliable every single time.",
  },
  {
    name: "James C.",
    text: "The crew installed a complete wet pipe system in our new warehouse. Clean work, on schedule, and they handled all the permits.",
  },
];

const duplicated = [...testimonials, ...testimonials, ...testimonials, ...testimonials];
---

<section class="w-full py-24 overflow-hidden" style="background: #fff8f7;">

  <!-- Header -->
  <div class="flex flex-col items-center text-center mb-14 px-6">
    <span class="as-label-caps mb-3 text-as-primary">WHAT OUR CLIENTS SAY</span>
    <h2 class="font-extrabold tracking-tighter" style="font-size: clamp(28px, 4vw, 44px); letter-spacing: -0.02em; color: #291715;">
      Trusted Across New Jersey &amp; Pennsylvania
    </h2>
  </div>

  <!-- Marquee -->
  <div class="relative w-full overflow-hidden">
    <!-- Fade edges -->
    <div class="absolute left-0 top-0 bottom-0 w-24 z-10 pointer-events-none" style="background: linear-gradient(to right, #fff8f7, transparent);"></div>
    <div class="absolute right-0 top-0 bottom-0 w-24 z-10 pointer-events-none" style="background: linear-gradient(to left, #fff8f7, transparent);"></div>

    <div class="as-testimonials-track flex w-fit hover:[animation-play-state:paused] cursor-grab active:cursor-grabbing">
      {duplicated.map((t) => (
        <div class="shrink-0 w-[320px] md:w-95 px-6 md:px-8 flex flex-col items-start border-r border-as-border">
          <div class="flex items-center gap-0.5 mb-4" style="color: #FBBC05;">
            ★★★★★
          </div>
          <p class="text-sm leading-relaxed mb-6 grow" style="color: #5d3f3b; font-style: italic;">
            "{t.text}"
          </p>
          <div class="flex items-center gap-3">
            <svg width="18" height="18" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" class="shrink-0">
              <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
              <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
              <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
              <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
            </svg>
            <div class="flex flex-col">
              <span class="text-[13px] font-bold" style="color: #291715;">{t.name}</span>
              <span class="text-[11px]" style="color: #5d3f3b; opacity: 0.6;">Google Review</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- CTA -->
  <div class="mt-14 flex justify-center">
    <a href="#" class="as-btn-primary inline-flex items-center gap-2 px-8 py-4 text-sm">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" class="w-4 h-4 shrink-0">
        <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
        <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
        <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
        <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
      </svg>
      Read All Google Reviews
    </a>
  </div>

</section>

<style>
  .as-testimonials-track {
    animation: as-testimonials-scroll 40s linear infinite;
  }

  @keyframes as-testimonials-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-25%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .as-testimonials-track { animation: none; }
  }
</style>
