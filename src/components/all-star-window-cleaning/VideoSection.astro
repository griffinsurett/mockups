---
---

<section class="w-full py-24 bg-[#0a0a0a] text-white flex flex-col items-center">

  <!-- Section Header -->
  <div class="flex flex-col items-center justify-center text-center mb-16 max-w-[600px] px-6">
    <span class="text-white text-[10px] font-bold tracking-[0.2em] uppercase mb-4">Follow Us</span>
    <h2 class="text-4xl md:text-5xl font-black uppercase tracking-tight text-white mb-5">See Us In Action</h2>
    <p class="text-[#a0a0a0] text-[13px] leading-relaxed max-w-[400px]">
      Follow along on social media for behind-the-scenes looks at our latest projects.
    </p>
  </div>

  <!-- Images Container -->
  <div class="flex flex-col md:flex-row items-center justify-center gap-4 md:gap-6 w-full max-w-[800px] px-6">

    <div class="relative w-full md:w-[340px] aspect-[4/5] md:aspect-[9/16] rounded-2xl overflow-hidden group cursor-pointer bg-gray-900 border border-white/10 shadow-2xl">
      <img
        src="https://images.unsplash.com/photo-1589939705384-5185137a7f0f?q=80&w=600&h=1066&auto=format&fit=crop"
        alt="Worker on site"
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 opacity-80"
      />
    </div>

    <div class="relative w-full md:w-[340px] aspect-[4/5] md:aspect-[9/16] rounded-2xl overflow-hidden group cursor-pointer bg-gray-900 border border-white/10 shadow-2xl">
      <img
        src="https://images.unsplash.com/photo-1504328345606-18bbc8c9d7d1?q=80&w=600&h=1066&auto=format&fit=crop"
        alt="Window cleaning action"
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 opacity-80"
      />
    </div>

  </div>
</section>
