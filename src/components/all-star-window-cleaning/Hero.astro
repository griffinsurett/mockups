---
import BackgroundMedia from "./BackgroundMedia.astro";
import Star from "./Star.astro";
import heroImg from "../../assets/all-star-window-cleaning/hero-img.webp";
---

<section class="relative w-full overflow-hidden flex items-center justify-center" style="height: clamp(500px, 80vh, 100dvh);">
  <BackgroundMedia
    backgroundMedia={{
      image: {
        src: heroImg,
        aboveTheFold: true,
      },
      overlayClass: "bg-black/40",
    }}
  />
  <!-- Bottom fade to black -->
  <div class="absolute inset-0 z-0" style="background: linear-gradient(to bottom, transparent 40%, #000 100%);"></div>

  <div class="relative z-10 flex flex-col items-center text-center gap-8 w-full px-6">
    <!-- Contained content -->
    <div class="flex flex-col items-center gap-6 max-w-5xl w-full">
      <p class="flex items-center gap-3 text-sm md:text-base font-semibold uppercase tracking-[0.2em]" style="color:#dcfb19">
        <Star class="text-xl" />
        Based in Sayreville, NJ &amp; Serving All of Central NJ
        <Star class="text-xl" />
      </p>
      <h1 class="text-white font-black uppercase leading-none text-5xl md:text-8xl drop-shadow-lg">
        All Star Shine Every Time
      </h1>
      <p class="text-white/70 text-base md:text-lg max-w-xl">
        Spotless windows for homes &amp; businesses across Central NJ. Free estimates, guaranteed satisfaction.
      </p>
    </div>

    <!-- Button outside container -->
    <a
      href="/all-star-window-cleaning/contact"
      class="bg-aswc-accent hover:bg-aswc-accent-hover text-white font-bold text-lg px-10 py-4 rounded transition-colors duration-200 tracking-wide"
    >
      Get a Free Estimate
    </a>
  </div>
</section>
