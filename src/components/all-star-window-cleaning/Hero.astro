---
import BackgroundMedia from "./BackgroundMedia.astro";
import Star from "./Star.astro";
import heroImg from "../../assets/all-star-window-cleaning/hero-img.webp";
---

<section class="relative w-full h-[80vh] overflow-hidden flex items-center justify-center">
  <BackgroundMedia
    backgroundMedia={{
      image: {
        src: heroImg,
        aboveTheFold: true,
      },
      overlayClass: "bg-black/55",
    }}
  />

  <div class="relative z-10 flex flex-col items-center text-center px-6 gap-6">
    <p class="flex items-center gap-3 text-sm md:text-base font-semibold uppercase tracking-[0.2em]" style="color:#dcfb19">
      <Star class="text-xl" />
      Based in Sayreville, NJ &amp; Serving All of Central NJ
      <Star class="text-xl" />
    </p>
    <h1 class="text-white uppercase leading-none text-5xl md:text-8xl drop-shadow-lg" style="font-family: var(--font-undergrad)">
      All Star <span style="-webkit-text-fill-color: transparent; -webkit-text-stroke: 2px white;">Shine</span> Every Time
    </h1>
    <p class="text-white/70 text-base md:text-lg max-w-xl">
      Window Cleaning · Power Washing · Gutter Cleaning · Junk Removal &amp; More — Residential &amp; Commercial. Free Estimates.
    </p>
    <a
      href="#contact"
      class="mt-2 bg-aswc-accent hover:bg-aswc-accent-hover text-white font-bold text-lg px-10 py-4 rounded transition-colors duration-200 tracking-wide"
    >
      Get a Free Estimate
    </a>
  </div>
</section>
