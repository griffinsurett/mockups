---
const towns = [
  "Sayreville", "South Amboy", "Perth Amboy", "Old Bridge", "Parlin",
  "South River", "Milltown", "East Brunswick", "New Brunswick", "Edison",
  "Woodbridge", "Carteret", "Rahway", "Linden", "Metuchen",
  "Highland Park", "Piscataway", "Bound Brook", "Somerville", "Bridgewater",
  "Freehold", "Manalapan", "Marlboro", "Matawan", "Aberdeen",
  "Keyport", "Keansburg", "Hazlet", "Holmdel", "Middletown",
  "Red Bank", "Long Branch", "Asbury Park", "Neptune", "Howell",
  "Lakewood", "Toms River", "Brick", "Jackson", "Monroe",
];
---

<section class="w-full bg-[#974ff5]">

  <!-- Split: Map | Towns -->
  <div class="flex flex-col md:flex-row min-h-[520px]">

    <!-- Map -->
    <div class="w-full md:w-1/2 min-h-[360px] md:min-h-0">
      <iframe
        title="All Star Window Cleaning — Sayreville NJ"
        src="https://maps.google.com/maps?q=Sayreville,NJ&output=embed&z=11"
        width="100%"
        height="100%"
        style="border:0; display:block; min-height:360px;"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
    </div>

    <!-- Towns checklist -->
    <div class="w-full md:w-1/2 py-10 px-8 lg:px-14 flex flex-col justify-center">
      <h3 class="text-xl font-black uppercase tracking-tight text-black mb-6">
        Areas We Cover
      </h3>
      <ul class="grid grid-cols-2 gap-x-6 gap-y-2.5">
        {towns.map((town) => (
          <li class="flex items-center gap-2 text-[0.875rem] font-semibold text-black">
            <svg class="w-4 h-4 shrink-0 text-black" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            {town}
          </li>
        ))}
      </ul>
      <p class="mt-6 text-[0.8rem] text-black/60 font-medium">
        Don't see your town? <a href="/all-star-window-cleaning/contact" class="underline hover:text-black transition-colors">Contact us</a> — we likely cover it.
      </p>
    </div>

  </div>

</section>
