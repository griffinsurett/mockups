---
import Star from "./Star.astro";

const testimonials = [
  {
    name: "maureen herndon",
    text: "Dylan has been cleaning my windows at my business for years!! He reliable, efficient and takes pride in his work!!! Highly recommend!!!",
  },
  {
    name: "Louis Dolan",
    text: "Hooked me up with a great deal and did an amazing job! Highly recommended",
  },
  {
    name: "James Page",
    text: "All star window cleaning is a wonderful company they come every other week to my establishment for a service cleaning as well as my home Dylann is a very professional hardworking individual that always gets the job done he helps us out and...",
  },
  {
    name: "Carin Spinola",
    text: "Called and got service on same day. It was amazing",
  }
];

const duplicatedTestimonials = [...testimonials, ...testimonials, ...testimonials, ...testimonials];
---

<section class="w-full py-24 bg-[#0a0a0a] overflow-hidden text-white flex flex-col items-center">

  <!-- Header -->
  <div class="flex flex-col items-center justify-center text-center mb-16">
    <p class="flex items-center gap-3 text-sm md:text-base font-semibold uppercase tracking-[0.2em] mb-3" style="color:#dcfb19">
      <Star class="text-base" />
      What Our Clients Say
      <Star class="text-base" />
    </p>
    <h2 class="text-4xl md:text-5xl font-black uppercase tracking-tight text-white">Trusted by Central NJ Homeowners</h2>
  </div>

  <!-- Marquee -->
  <div class="relative w-full max-w-[1600px] mx-auto overflow-hidden flex flex-col items-center">
    <div class="absolute left-0 top-0 bottom-0 w-32 bg-gradient-to-r from-[#0a0a0a] to-transparent z-10 pointer-events-none"></div>
    <div class="absolute right-0 top-0 bottom-0 w-32 bg-gradient-to-l from-[#0a0a0a] to-transparent z-10 pointer-events-none"></div>

    <div class="flex w-fit animate-marquee hover:[animation-play-state:paused] cursor-grab active:cursor-grabbing">
      {duplicatedTestimonials.map((testimonial) => (
        <div class="flex-shrink-0 w-[350px] md:w-[400px] px-6 md:px-10 flex flex-col items-start border-r border-white/10">
          <div class="flex items-center gap-1 mb-5">
            <Star /><Star /><Star /><Star /><Star />
          </div>
          <p class="text-white/60 text-[14px] leading-relaxed italic mb-8 grow">
            "{testimonial.text}"
          </p>
          <div class="flex items-center gap-3">
            <svg width="20" height="20" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" class="shrink-0">
              <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
              <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
              <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
              <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
              <path fill="none" d="M0 0h48v48H0z"/>
            </svg>
            <div class="flex flex-col">
              <span class="text-[13px] font-bold text-white mb-0.5">{testimonial.name}</span>
              <span class="text-[11px] text-white/40">Google Review</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- CTA -->
  <div class="mt-16 relative z-20">
    <a href="#" class="flex items-center justify-center gap-3 border border-white/20 bg-white/10 hover:bg-white/20 px-10 py-4 text-[11px] font-bold tracking-[0.15em] uppercase text-white transition-colors shadow-md">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" class="w-4 h-4">
        <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
        <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
        <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
        <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
        <path fill="none" d="M0 0h48v48H0z"/>
      </svg>
      Read All Google Reviews
    </a>
  </div>
</section>
