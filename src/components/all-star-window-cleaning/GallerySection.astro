---

<section class="w-full py-16 lg:py-[50px] bg-white overflow-x-hidden">
  <div class="max-w-[1200px] mx-auto text-center">

    <h2 class="font-black text-[36px] lg:text-[45px] leading-[1.1] text-black px-6 lg:px-12 uppercase tracking-tight">
      Image Gallery
    </h2>
    <p class="mt-4 text-[16px] leading-6 max-w-4xl mx-auto px-6 lg:px-12 text-[#555]">
      A look at our work across Central NJ — spotless results every time.
    </p>

    <div class="mt-10 relative" id="aswc-gallery">
      <img
        src="/all-star-window-cleaning/favicon.png"
        alt=""
        aria-hidden="true"
        class="absolute -top-24 right-6 lg:right-12 w-48 h-48 object-contain z-10"
      />
      <div class="overflow-hidden">
        <div id="aswc-track" class="flex transition-transform duration-500 ease-in-out">
          {images.map((img) => (
            <div class="flex-none aswc-slide">
              <img
                src={img.src}
                alt={img.alt}
                class="w-full aspect-[3/4] object-cover"
                loading="lazy"
              />
            </div>
          ))}
        </div>
      </div>

      <button
        id="aswc-prev"
        aria-label="Previous image"
        class="absolute left-2 top-1/2 -translate-y-1/2 w-10 h-10 lg:w-12 lg:h-12 bg-black text-white grid place-items-center hover:bg-neutral-800 disabled:opacity-40 transition-opacity z-10"
      >
        &#8249;
      </button>

      <button
        id="aswc-next"
        aria-label="Next image"
        class="absolute right-2 top-1/2 -translate-y-1/2 w-10 h-10 lg:w-12 lg:h-12 bg-black text-white grid place-items-center hover:bg-neutral-800 disabled:opacity-40 transition-opacity z-10"
      >
        &#8250;
      </button>
    </div>

    <nav id="aswc-dots" class="mt-6 flex justify-center gap-2 px-6 lg:px-12" aria-label="Gallery pagination"></nav>
  </div>
</section>

<script>
  (function () {
    const total = document.querySelectorAll<HTMLElement>(".aswc-slide").length;
    let spv = 3;
    let index = 0;

    const track = document.getElementById("aswc-track") as HTMLElement;
    const prev = document.getElementById("aswc-prev") as HTMLButtonElement;
    const next = document.getElementById("aswc-next") as HTMLButtonElement;
    const dotsNav = document.getElementById("aswc-dots") as HTMLElement;
    const slides = document.querySelectorAll<HTMLElement>(".aswc-slide");

    function getSpv() {
      return window.innerWidth >= 1024 ? 3 : window.innerWidth >= 640 ? 2 : 1;
    }

    function maxIndex() {
      return Math.max(0, total - spv);
    }

    function setSlideSizes() {
      // track spans all slides; each slide is 1/spv of the viewport
      track.style.width = `${(total / spv) * 100}%`;
      slides.forEach((s) => {
        s.style.width = `${100 / total}%`;
      });
    }

    function render() {
      // shift by (index * slideWidth) where slideWidth = 100%/spv of container
      const pct = (index / total) * 100;
      track.style.transform = `translateX(-${pct}%)`;
      prev.disabled = index === 0;
      next.disabled = index >= maxIndex();

      dotsNav.querySelectorAll("button").forEach((btn, i) => {
        btn.className = i === index
          ? "w-3 h-3 rounded-full bg-[#974ff5] scale-[1.3] transition-all duration-300"
          : "w-3 h-3 rounded-full bg-black/20 hover:bg-black/40 transition-all duration-300";
      });
    }

    function buildDots() {
      dotsNav.innerHTML = "";
      const count = maxIndex() + 1;
      for (let i = 0; i < count; i++) {
        const btn = document.createElement("button");
        btn.type = "button";
        btn.setAttribute("aria-label", `Go to image ${i + 1}`);
        btn.addEventListener("click", () => { index = i; render(); });
        dotsNav.appendChild(btn);
      }
    }

    function update() {
      spv = getSpv();
      index = Math.min(index, maxIndex());
      setSlideSizes();
      buildDots();
      render();
    }

    prev.addEventListener("click", () => { index = Math.max(0, index - 1); render(); });
    next.addEventListener("click", () => { index = Math.min(maxIndex(), index + 1); render(); });
    window.addEventListener("resize", update, { passive: true });

    update();
  })();
</script>
