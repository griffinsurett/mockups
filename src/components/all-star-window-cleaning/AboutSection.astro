---
import BackgroundMedia from "./BackgroundMedia.astro";
import GoogleRating from "./GoogleRating.astro";

const ownerImg = "/all-star-window-cleaning/owner.jpg";
---

<section class="w-full bg-[#f4f3ef] text-black flex flex-col md:flex-row min-h-[600px]">

  <!-- Left: owner image -->
  <div class="relative w-full md:w-1/2 min-h-90 md:min-h-0">
    <BackgroundMedia
      backgroundMedia={{
        image: { src: ownerImg },
        overlayClass: "bg-black/10",
      }}
    />
  </div>

  <!-- Right: content -->
  <div class="w-full md:w-1/2 py-20 px-8 lg:px-16 flex flex-col justify-center">
    <h2 class="text-3xl md:text-4xl font-black uppercase tracking-tight text-black mb-6">
      About All Star Window Cleaning
    </h2>
    <p class="text-[14px] text-[#444] leading-relaxed mb-4">
      All Star Window Cleaning is a Central NJ-based cleaning company built on reliability, quality, and fair pricing. We handle window cleaning, power washing, gutter cleaning, junk removal, and more — serving both residential and commercial customers across Middlesex, Monmouth, and Somerset counties.
    </p>
    <p class="text-[14px] text-[#444] leading-relaxed mb-8">
      Every job is done right the first time. We offer free estimates, flexible scheduling, and a satisfaction guarantee on every service. The company is owner-operated by Dylan, who takes personal pride in every property we touch.
    </p>
    <div class="flex items-center gap-6 flex-wrap">
      <a
        href="/all-star-window-cleaning/contact"
        class="inline-flex items-center justify-center px-8 py-3 bg-aswc-accent hover:bg-aswc-accent-hover text-white font-bold text-[13px] tracking-widest uppercase rounded transition-colors duration-200"
      >
        Get a Free Estimate
      </a>
      <GoogleRating textColor="#1a1a1a" />
    </div>
  </div>

</section>
