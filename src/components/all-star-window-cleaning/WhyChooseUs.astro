---
import BackgroundMedia from "./BackgroundMedia.astro";
import { MdCleaningServices, MdVerified } from "react-icons/md";
import { FaStar, FaLightbulb } from "react-icons/fa";
import { GiWaterDrop } from "react-icons/gi";

const imgSrc = "/all-star-window-cleaning/commercial.webp";

const reasons = [
  {
    Icon: FaStar,
    title: "5-Star Rated on Google",
    body: "Our customers consistently rate us 5 stars. We take pride in every job and won't leave until you're satisfied.",
  },
  {
    Icon: MdCleaningServices,
    title: "Same-Day Service Available",
    body: "Need it done fast? We offer same-day and next-day appointments across Central NJ.",
  },
  {
    Icon: MdVerified,
    title: "Satisfaction Guaranteed",
    body: "Not happy? We come back and make it right. Every time, no questions asked.",
  },
  {
    Icon: GiWaterDrop,
    title: "Streak-Free Results",
    body: "Professional-grade equipment and technique means crystal-clear, streak-free windows on every visit.",
  },
];
---

<section class="w-full bg-white text-black flex flex-col md:flex-row-reverse min-h-[600px]">

  <!-- Right: image -->
  <div class="relative w-full md:w-1/2 min-h-90 md:min-h-0">
    <BackgroundMedia
      backgroundMedia={{
        image: { src: imgSrc },
        overlayClass: "bg-black/10",
      }}
    />
  </div>

  <!-- Left: content -->
  <div class="w-full md:w-1/2 py-20 px-8 lg:px-16 flex flex-col justify-center bg-white">
    <div class="flex items-center gap-4 mb-10">
      <h2 class="text-3xl md:text-4xl font-black uppercase tracking-tight text-black">
        The All Star Difference
      </h2>
      <img src="/all-star-window-cleaning/favicon.png" alt="" class="w-14 h-14 object-contain shrink-0" aria-hidden="true" />
    </div>

    <ul class="flex flex-col gap-7">
      {reasons.map(({ Icon, title, body }) => (
        <li class="flex items-start gap-4">
          <span class="shrink-0 w-11 h-11 rounded-full p-0.5 grid place-items-center" style="background: linear-gradient(180deg, #f9ebc2 0%, #cba14b 100%);">
            <span class="w-full h-full rounded-full bg-black grid place-items-center" style="color:#dcfb19;">
              <Icon size={18} />
            </span>
          </span>
          <div>
            <p class="font-black text-[15px] uppercase tracking-wide text-black mb-1">{title}</p>
            <p class="text-[13px] text-[#555] leading-relaxed">{body}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>

</section>
