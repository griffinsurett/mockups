---
const year = new Date().getFullYear();
---

<footer>
  <!-- CTA strip — purple → black gradient -->
  <div id="contact" style="background: linear-gradient(180deg, #974ff5 0%, #000 100%);">
    <div class="max-w-[1200px] mx-auto px-6 py-14 lg:py-20 text-center">
      <h2 class="font-black text-[24px] lg:text-[28px] text-white uppercase tracking-tight">
        Ready for Spotless Windows?
      </h2>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="#"
          class="inline-flex items-center justify-center px-10 h-[50px] bg-aswc-accent hover:bg-aswc-accent-hover text-white font-bold text-[18px] rounded tracking-wide transition-colors duration-200"
        >
          Get a Free Estimate
        </a>
        <div class="text-center">
          <div class="text-[0.78rem] uppercase tracking-[0.04em] text-[#dcfb19]">Call Us Today</div>
          <a href="tel:7325550192" class="text-[1.45rem] font-extrabold text-white tracking-tight">(732) 555-0192</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Black footer bottom -->
  <div class="bg-black text-white" style="margin-top:-1px;">
    <div class="max-w-[1440px] mx-auto px-6 lg:px-[81px] pt-14 pb-8 text-center">
      <img
        src="/all-star-window-cleaning/logo.png"
        alt="All Star Window Cleaning"
        class="mx-auto w-[140px] lg:w-[200px] object-contain"
      />
      <div class="mt-8 border-t border-white/10"></div>

      <div class="mt-6 flex flex-wrap items-center justify-center gap-x-5 gap-y-2 text-[14px] lg:text-[15px] text-white/70">
        <a href="#" class="hover:text-white transition-colors">Privacy Policy</a>
        <span class="text-white/30">·</span>
        <a href="#" class="hover:text-white transition-colors">Terms of Service</a>
        <span class="text-white/30">·</span>
        <a href="#" class="hover:text-white transition-colors">Cookie Policy</a>
      </div>

      <div class="mt-4 flex flex-col lg:flex-row gap-2 lg:gap-0 lg:justify-between items-center text-[14px] lg:text-[15px] text-white/70">
        <span>&copy;{year} All Star Window Cleaning. All Rights Reserved.</span>
        <a href="https://griffinswebservices.com" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">
          Built By Griffin's Web Services
        </a>
      </div>
    </div>
  </div>
</footer>
