---
---
<section class="w-full bg-[#030712] py-24 px-8 md:px-16 border-b-[6px] border-[#d39a4d] overflow-hidden relative">
  <div class="absolute top-1/4 left-1/4 w-[400px] h-[400px] bg-[#d39a4d]/10 rounded-full blur-[120px] pointer-events-none z-0"></div>
  <div class="absolute bottom-1/4 right-1/4 w-[400px] h-[400px] bg-yellow-500/5 rounded-full blur-[150px] pointer-events-none z-0"></div>

  <div class="max-w-7xl mx-auto relative z-10">
    <div class="flex flex-col items-center mb-16 text-center">
      <span class="text-xs md:text-sm font-black tracking-[0.3em] text-[#df9c2c] uppercase mb-3" style="font-family: 'Inter', sans-serif;">LIMITED TIME OFFER</span>
      <h2 class="text-3xl md:text-[42px] text-white font-bold leading-tight mb-6 drop-shadow-xl uppercase" style="font-family: 'Playfair Display', serif;">
        THIS MONTH'S FEATURED DEAL
      </h2>
      <div class="w-12 h-1 bg-[#d39a4d] shadow-[0_0_10px_rgba(211,154,77,0.5)]"></div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-stretch">

      <div class="lg:col-span-5 flex flex-col justify-between bg-black border border-gray-900 overflow-hidden relative group p-6">
        <div class="w-full aspect-[16/10] overflow-hidden relative border border-gray-900">
          <img src="/car-detailing-cen-fl/assets/images/special.png" alt="May Monthly Special Bugatti Chiron" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent pointer-events-none"></div>
          <div class="absolute top-4 left-4 bg-red-600 text-white text-[10px] font-black px-3 py-1 uppercase tracking-widest shadow-lg animate-pulse">
            HOT DEAL
          </div>
        </div>

        <div class="mt-6 bg-gradient-to-r from-[#5c3c15] via-[#8c6239] to-[#5c3c15] border border-[#df9c2c] p-5 text-center relative overflow-hidden">
          <div class="absolute inset-0 bg-white/5 pointer-events-none"></div>
          <h4 class="text-xs font-black text-white uppercase tracking-widest mb-1" style="font-family: 'Inter', sans-serif;">CELEBRATING MOM THIS MONTH</h4>
          <p class="text-lg font-bold text-[#df9c2c]" style="font-family: 'Playfair Display', serif;">Every Mom Saves 15%</p>
          <p class="text-[10px] text-white/80 uppercase tracking-wider mt-1" style="font-family: 'Inter', sans-serif;">All Month Long &bull; Every Make & Model</p>
        </div>
      </div>

      <div class="lg:col-span-7 bg-black border border-gray-900 p-8 md:p-10 flex flex-col justify-between relative">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center border-b border-gray-900 pb-8 mb-8 gap-4">
          <div class="flex flex-col">
            <span class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1" style="font-family: 'Inter', sans-serif;">ANY MAKE OR MODEL</span>
            <h3 class="text-2xl md:text-3xl text-white font-bold" style="font-family: 'Playfair Display', serif;">Inside-Out Complete Detail</h3>
          </div>
          <div class="flex items-baseline gap-2">
            <span class="text-4xl md:text-5xl font-black text-[#df9c2c]" style="font-family: 'Playfair Display', serif;">$199.99</span>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-10">
          <div class="flex items-start gap-3 group/item">
            <i class="ph-fill ph-cloud-fog text-xl text-[#df9c2c] bg-[#df9c2c]/10 p-2 rounded-sm group-hover/item:bg-[#df9c2c] group-hover/item:text-black transition-all"></i>
            <div class="flex flex-col">
              <span class="text-xs font-black text-white uppercase tracking-wider" style="font-family: 'Inter', sans-serif;">HOT STEAM SEAT TREATMENT</span>
              <span class="text-[11px] text-gray-400 leading-normal mt-0.5" style="font-family: 'Inter', sans-serif;">Seats & floors thoroughly steam extracted</span>
            </div>
          </div>
          <div class="flex items-start gap-3 group/item">
            <i class="ph-fill ph-drop text-xl text-[#df9c2c] bg-[#df9c2c]/10 p-2 rounded-sm group-hover/item:bg-[#df9c2c] group-hover/item:text-black transition-all"></i>
            <div class="flex flex-col">
              <span class="text-xs font-black text-white uppercase tracking-wider" style="font-family: 'Inter', sans-serif;">GLASS WATER REPELLENT</span>
              <span class="text-[11px] text-gray-400 leading-normal mt-0.5" style="font-family: 'Inter', sans-serif;">Water-beading treatment on every window</span>
            </div>
          </div>
          <div class="flex items-start gap-3 group/item">
            <i class="ph-fill ph-sparkles text-xl text-[#df9c2c] bg-[#df9c2c]/10 p-2 rounded-sm group-hover/item:bg-[#df9c2c] group-hover/item:text-black transition-all"></i>
            <div class="flex flex-col">
              <span class="text-xs font-black text-white uppercase tracking-wider" style="font-family: 'Inter', sans-serif;">INTERIOR TRIM GUARD</span>
              <span class="text-[11px] text-gray-400 leading-normal mt-0.5" style="font-family: 'Inter', sans-serif;">Protective coating on all cabin plastics</span>
            </div>
          </div>
          <div class="flex items-start gap-3 group/item">
            <i class="ph-fill ph-shield text-xl text-[#df9c2c] bg-[#df9c2c]/10 p-2 rounded-sm group-hover/item:bg-[#df9c2c] group-hover/item:text-black transition-all"></i>
            <div class="flex flex-col">
              <span class="text-xs font-black text-white uppercase tracking-wider" style="font-family: 'Inter', sans-serif;">FULL INTERIOR SANITIZATION</span>
              <span class="text-[11px] text-gray-400 leading-normal mt-0.5" style="font-family: 'Inter', sans-serif;">Germs and bacteria eliminated throughout</span>
            </div>
          </div>
          <div class="flex items-start gap-3 group/item">
            <i class="ph-fill ph-wind text-xl text-[#df9c2c] bg-[#df9c2c]/10 p-2 rounded-sm group-hover/item:bg-[#df9c2c] group-hover/item:text-black transition-all"></i>
            <div class="flex flex-col">
              <span class="text-xs font-black text-white uppercase tracking-wider" style="font-family: 'Inter', sans-serif;">AIR FILTER SERVICE</span>
              <span class="text-[11px] text-gray-400 leading-normal mt-0.5" style="font-family: 'Inter', sans-serif;">Cabin filter cleared of dust and buildup</span>
            </div>
          </div>
          <div class="flex items-start gap-3 group/item">
            <i class="ph-fill ph-car text-xl text-[#df9c2c] bg-[#df9c2c]/10 p-2 rounded-sm group-hover/item:bg-[#df9c2c] group-hover/item:text-black transition-all"></i>
            <div class="flex flex-col">
              <span class="text-xs font-black text-white uppercase tracking-wider" style="font-family: 'Inter', sans-serif;">HAND WASH & POLISH</span>
              <span class="text-[11px] text-gray-400 leading-normal mt-0.5" style="font-family: 'Inter', sans-serif;">Pressure washed then towel-dried by hand</span>
            </div>
          </div>
          <div class="flex items-start gap-3 group/item">
            <i class="ph-fill ph-circle text-xl text-[#df9c2c] bg-[#df9c2c]/10 p-2 rounded-sm group-hover/item:bg-[#df9c2c] group-hover/item:text-black transition-all"></i>
            <div class="flex flex-col">
              <span class="text-xs font-black text-white uppercase tracking-wider" style="font-family: 'Inter', sans-serif;">WHEEL ARCH BLAST</span>
              <span class="text-[11px] text-gray-400 leading-normal mt-0.5" style="font-family: 'Inter', sans-serif;">High-pressure clean inside every wheel well</span>
            </div>
          </div>
          <div class="flex items-start gap-3 group/item">
            <i class="ph-fill ph-seal text-xl text-[#df9c2c] bg-[#df9c2c]/10 p-2 rounded-sm group-hover/item:bg-[#df9c2c] group-hover/item:text-black transition-all"></i>
            <div class="flex flex-col">
              <span class="text-xs font-black text-white uppercase tracking-wider" style="font-family: 'Inter', sans-serif;">PROTECTIVE WAX COAT</span>
              <span class="text-[11px] text-gray-400 leading-normal mt-0.5" style="font-family: 'Inter', sans-serif;">Gloss-enhancing shield over the paint</span>
            </div>
          </div>
          <div class="flex items-start gap-3 group/item sm:col-span-2">
            <i class="ph-fill ph-sun text-xl text-[#df9c2c] bg-[#df9c2c]/10 p-2 rounded-sm group-hover/item:bg-[#df9c2c] group-hover/item:text-black transition-all"></i>
            <div class="flex flex-col">
              <span class="text-xs font-black text-white uppercase tracking-wider" style="font-family: 'Inter', sans-serif;">TIRES & TRIM FINISH</span>
              <span class="text-[11px] text-gray-400 leading-normal mt-0.5" style="font-family: 'Inter', sans-serif;">Shine dressing on tires and exterior trim for a showroom finish</span>
            </div>
          </div>
        </div>

        <a href="tel:3863073785" class="bg-gradient-to-r from-[#d39a4d] to-[#fdd78c] text-black text-center font-bold text-sm tracking-widest py-4 px-8 hover:bg-[#fdd78c] hover:text-black transition-colors uppercase flex items-center justify-center gap-3 shadow-lg shadow-[#d39a4d]/30" style="font-family: 'Inter', sans-serif;">
          <i class="ph-fill ph-phone-call text-lg"></i>
          LOCK IN THIS DEAL — CALL (386) 307-3785
        </a>
      </div>

    </div>
  </div>
</section>
