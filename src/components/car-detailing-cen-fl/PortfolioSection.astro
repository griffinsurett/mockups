---
import BeforeAfterSlider from './BeforeAfterSlider';

const projects = [
  {
    label: "Full Interior Detail — Sedan",
    before: "/car-detailing-cen-fl/assets/images/gallery/gallery-1.jpg",
    after:  "/car-detailing-cen-fl/assets/images/gallery/gallery-2.jpg",
  },
  {
    label: "Exterior Paint Correction — SUV",
    before: "/car-detailing-cen-fl/assets/images/gallery/gallery-3.jpg",
    after:  "/car-detailing-cen-fl/assets/images/gallery/gallery-4.jpg",
  },
  {
    label: "Ceramic Coating — Sports Car",
    before: "/car-detailing-cen-fl/assets/images/gallery/gallery-5.jpg",
    after:  "/car-detailing-cen-fl/assets/images/gallery/gallery-6.jpg",
  },
];
---

<section class="w-full bg-black py-20 px-6 md:px-16 border-t border-white/10">
  <div class="max-w-7xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-14">
      <p class="text-xs font-bold tracking-[0.3em] uppercase mb-3 bg-linear-to-r from-[#d39a4d] to-[#fdd78c] bg-clip-text text-transparent" style="font-family: 'Inter', sans-serif;">
        SEE THE DIFFERENCE
      </p>
      <h2 class="text-3xl md:text-5xl font-bold text-white leading-tight" style="font-family: 'Playfair Display', serif;">
        Before &amp; After
      </h2>
      <div class="w-12 h-0.5 mx-auto mt-6" style="background: linear-gradient(to right, #d39a4d, #fdd78c);"></div>
      <p class="text-white/40 text-sm mt-4 max-w-md mx-auto" style="font-family: 'Inter', sans-serif;">
        Drag the slider to reveal the transformation. Every vehicle tells a story.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {projects.map((p) => (
        <BeforeAfterSlider
          client:visible
          before={p.before}
          after={p.after}
          label={p.label}
          className="border border-white/10"
        />
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-12">
      <a href="/car-detailing-cen-fl/contact" class="inline-block border-2 border-white text-white font-bold text-sm tracking-widest py-3 px-8 hover:bg-white hover:text-black transition-colors duration-300 uppercase rounded-sm bg-black/20" style="font-family: 'Inter', sans-serif;">
        BOOK YOUR TRANSFORMATION
      </a>
    </div>

  </div>
</section>
