---
import Logo from './Logo.astro';
import SocialIcons from './SocialIcons';
---
<footer class="w-full bg-black text-white pt-16 pb-8 px-8 md:px-16">
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-12 mb-16 items-start">

    <!-- Logo -->
    <div class="flex flex-col items-center md:items-start">
      <Logo class="w-96 md:w-96" />
    </div>

    <!-- Contact -->
    <div class="flex flex-col text-center md:text-left">
      <h4 class="text-base font-bold mb-4 tracking-widest uppercase" style="font-family: 'Playfair Display', serif;">CONTACT US</h4>
      <a href="tel:3863073785" class="flex items-center gap-2 text-gray-300 text-sm mb-2 hover:text-[#d39a4d] transition-colors" style="font-family: 'Inter', sans-serif;">
        <i class="ph-fill ph-phone text-[#d39a4d] text-base"></i>
        (386) 307-3785
      </a>
      <p class="text-gray-300 text-sm" style="font-family: 'Inter', sans-serif;">Kevin Burtt — Owner/Operator</p>
    </div>

    <!-- Location -->
    <div class="flex flex-col text-center md:text-left">
      <h4 class="text-base font-bold mb-4 tracking-widest uppercase" style="font-family: 'Playfair Display', serif;">LOCATION</h4>
      <p class="text-sm font-bold text-white mb-2" style="font-family: 'Inter', sans-serif;">Serving Central Florida</p>
      <p class="text-gray-400 text-xs leading-relaxed" style="font-family: 'Inter', sans-serif;">Daytona Beach &bull; Ocala &bull; The Villages &bull; Clermont &bull; Winter Garden &bull; Orlando &bull; Oviedo &bull; Altamonte Springs &bull; Apopka &bull; Winter Park &bull; Deland &bull; Orange City</p>
    </div>

    <!-- Follow Us -->
    <div class="flex flex-col items-center md:items-start">
      <h4 class="text-base font-bold mb-4 tracking-widest uppercase" style="font-family: 'Playfair Display', serif;">FOLLOW US</h4>
      <SocialIcons client:load />
    </div>

  </div>

  <div class="max-w-7xl mx-auto text-center pt-8 border-t border-white/10">
    <p class="text-[11px] text-gray-400 leading-relaxed" style="font-family: 'Inter', sans-serif;">
      © {new Date().getFullYear()} Central FLA. Auto Detail LLC. All rights reserved. The content on this website is owned by us and our licensors. Do not copy any content (including images) without our consent.<br/>
      <a href="#" class="underline hover:text-white transition-colors">Privacy</a> | <a href="#" class="underline hover:text-white transition-colors">Terms of Use</a>
    </p>
  </div>
</footer>
