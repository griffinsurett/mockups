---
---
<section id="pricing" class="w-full bg-black text-white py-24 px-8 md:px-16 border-b-[6px] border-[#d39a4d]">
  <div class="max-w-7xl mx-auto flex flex-col items-center">

    <div class="flex flex-col items-center mb-20 text-center">
      <h2 class="text-3xl md:text-[42px] text-white font-bold leading-tight mb-6 drop-shadow-xl" style="font-family: 'Playfair Display', serif;">
        PREMIUM PRICING PACKAGES
      </h2>
      <div class="w-12 h-1 bg-[#d39a4d] shadow-[0_0_10px_rgba(211,154,77,0.5)]"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 w-full max-w-5xl mb-24">

      <!-- Sedan & Coupe Card -->
      <div class="bg-black border border-gray-900 overflow-hidden flex flex-col relative group transition-all duration-500 hover:border-gray-700 hover:shadow-2xl hover:shadow-[#d39a4d]/10">
        <div class="absolute inset-0 bg-gradient-to-b from-gray-900/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
        <div class="p-8 border-b border-gray-900 flex items-center justify-between relative z-10">
          <div class="flex items-center gap-4">
            <i class="ph-light ph-car text-4xl text-white"></i>
            <h3 class="text-lg font-extrabold tracking-widest uppercase text-white" style="font-family: 'Inter', sans-serif;">SEDAN & COUPE</h3>
          </div>
        </div>
        <div class="p-8 flex-grow flex flex-col justify-between relative z-10">
          <div class="space-y-8 mb-12">
            <div class="flex justify-between items-center group/item cursor-default">
              <div class="flex items-center gap-4">
                <i class="ph-light ph-armchair text-2xl text-[#d39a4d] opacity-80 group-hover/item:opacity-100 transition-opacity"></i>
                <span class="text-sm font-bold tracking-widest text-gray-300 group-hover/item:text-white transition-colors" style="font-family: 'Inter', sans-serif;">INTERIOR DETAIL</span>
              </div>
              <span class="text-2xl text-white group-hover/item:text-[#d39a4d] transition-colors" style="font-family: 'Playfair Display', serif;">$140</span>
            </div>
            <div class="flex justify-between items-center group/item cursor-default">
              <div class="flex items-center gap-4">
                <i class="ph-light ph-drop text-2xl text-[#d39a4d] opacity-80 group-hover/item:opacity-100 transition-opacity"></i>
                <span class="text-sm font-bold tracking-widest text-gray-300 group-hover/item:text-white transition-colors" style="font-family: 'Inter', sans-serif;">EXTERIOR DETAIL</span>
              </div>
              <span class="text-2xl text-white group-hover/item:text-[#d39a4d] transition-colors" style="font-family: 'Playfair Display', serif;">$70</span>
            </div>
          </div>
          <div class="relative bg-gradient-to-r from-[#01060d] via-[#5c3c15]/40 to-[#01060d] border border-[#d39a4d] p-4 md:p-6 mt-auto">
            <div class="absolute -top-3 left-6 bg-gradient-to-r from-[#d39a4d] to-[#fdd78c] text-black text-[10px] font-extrabold px-3 py-1 uppercase tracking-widest shadow-lg">
              MOST POPULAR
            </div>
            <div class="flex justify-between items-center mt-2">
              <div class="flex items-center gap-2 md:gap-4">
                <i class="ph-fill ph-sparkle text-2xl md:text-3xl text-[#d39a4d]"></i>
                <div class="flex flex-col">
                  <span class="text-sm md:text-base font-extrabold tracking-widest text-white uppercase" style="font-family: 'Inter', sans-serif;">FULL DETAIL</span>
                  <span class="text-[10px] md:text-[11px] text-gray-300 uppercase tracking-widest font-bold" style="font-family: 'Inter', sans-serif;">MAY SPECIAL &bull; INTERIOR + EXTERIOR</span>
                </div>
              </div>
              <span class="text-2xl md:text-4xl font-bold text-[#df9c2c]" style="font-family: 'Playfair Display', serif;">$199.99</span>
            </div>
          </div>
        </div>
      </div>

      <!-- SUV & Truck Card -->
      <div class="bg-black border border-gray-900 overflow-hidden flex flex-col relative group transition-all duration-500 hover:border-gray-700 hover:shadow-2xl hover:shadow-[#d39a4d]/10">
        <div class="absolute inset-0 bg-gradient-to-b from-gray-900/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
        <div class="p-8 border-b border-gray-900 flex items-center justify-between relative z-10">
          <div class="flex items-center gap-4">
            <i class="ph-light ph-jeep text-4xl text-white"></i>
            <h3 class="text-lg font-extrabold tracking-widest uppercase text-white" style="font-family: 'Inter', sans-serif;">SUV & TRUCK</h3>
          </div>
        </div>
        <div class="p-8 flex-grow flex flex-col justify-between relative z-10">
          <div class="space-y-8 mb-12">
            <div class="flex justify-between items-center group/item cursor-default">
              <div class="flex items-center gap-4">
                <i class="ph-light ph-armchair text-2xl text-[#d39a4d] opacity-80 group-hover/item:opacity-100 transition-opacity"></i>
                <span class="text-sm font-bold tracking-widest text-gray-300 group-hover/item:text-white transition-colors" style="font-family: 'Inter', sans-serif;">INTERIOR DETAIL</span>
              </div>
              <span class="text-2xl text-white group-hover/item:text-[#d39a4d] transition-colors" style="font-family: 'Playfair Display', serif;">$165</span>
            </div>
            <div class="flex justify-between items-center group/item cursor-default">
              <div class="flex items-center gap-4">
                <i class="ph-light ph-drop text-2xl text-[#d39a4d] opacity-80 group-hover/item:opacity-100 transition-opacity"></i>
                <span class="text-sm font-bold tracking-widest text-gray-300 group-hover/item:text-white transition-colors" style="font-family: 'Inter', sans-serif;">EXTERIOR DETAIL</span>
              </div>
              <span class="text-2xl text-white group-hover/item:text-[#d39a4d] transition-colors" style="font-family: 'Playfair Display', serif;">$75</span>
            </div>
          </div>
          <div class="relative bg-gradient-to-r from-gray-900 via-gray-800/40 to-gray-900 border border-gray-700 p-4 md:p-6 mt-auto transition-colors duration-500 group-hover:border-gray-500">
            <div class="flex justify-between items-center mt-2">
              <div class="flex items-center gap-2 md:gap-4">
                <i class="ph-fill ph-sparkle text-2xl md:text-3xl text-[#df9c2c] transition-colors"></i>
                <div class="flex flex-col">
                  <span class="text-sm md:text-base font-extrabold tracking-widest text-white uppercase" style="font-family: 'Inter', sans-serif;">FULL DETAIL</span>
                  <span class="text-[10px] md:text-[11px] text-gray-300 uppercase tracking-widest font-bold" style="font-family: 'Inter', sans-serif;">MAY SPECIAL &bull; INTERIOR + EXTERIOR</span>
                </div>
              </div>
              <span class="text-2xl md:text-4xl font-bold text-[#df9c2c]" style="font-family: 'Playfair Display', serif;">$199.99</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Add-Ons -->
    <div class="w-full max-w-5xl mb-16">
      <h3 class="text-2xl text-white font-bold mb-8 text-center drop-shadow-md" style="font-family: 'Playfair Display', serif;">POPULAR ADD-ONS</h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="bg-black border border-gray-900 p-8 flex flex-col items-center text-center group hover:bg-gray-900 hover:border-gray-700 transition-all duration-300">
          <i class="ph-light ph-engine text-4xl mb-4 text-[#d39a4d] group-hover:scale-110 transition-transform duration-300"></i>
          <span class="text-[11px] font-extrabold tracking-widest text-gray-300 uppercase mb-2" style="font-family: 'Inter', sans-serif;">ENGINE BAY</span>
          <span class="text-xl text-white" style="font-family: 'Playfair Display', serif;">$75</span>
        </div>
        <div class="bg-black border border-gray-900 p-8 flex flex-col items-center text-center group hover:bg-gray-900 hover:border-gray-700 transition-all duration-300">
          <i class="ph-light ph-paw-print text-4xl mb-4 text-[#d39a4d] group-hover:scale-110 transition-transform duration-300"></i>
          <span class="text-[11px] font-extrabold tracking-widest text-gray-300 uppercase mb-2" style="font-family: 'Inter', sans-serif;">DOG HAIR</span>
          <span class="text-xl text-white" style="font-family: 'Playfair Display', serif;">$50</span>
        </div>
        <div class="bg-black border border-gray-900 p-8 flex flex-col items-center text-center group hover:bg-gray-900 hover:border-gray-700 transition-all duration-300">
          <i class="ph-light ph-wind text-4xl mb-4 text-[#d39a4d] group-hover:scale-110 transition-transform duration-300"></i>
          <span class="text-[11px] font-extrabold tracking-widest text-gray-300 uppercase mb-2" style="font-family: 'Inter', sans-serif;">ODOR REMOVAL</span>
          <span class="text-xl text-white" style="font-family: 'Playfair Display', serif;">$125</span>
        </div>
        <div class="bg-black border border-gray-900 p-8 flex flex-col items-center text-center group hover:bg-gray-900 hover:border-gray-700 transition-all duration-300">
          <i class="ph-light ph-car-profile text-4xl mb-4 text-[#d39a4d] group-hover:scale-110 transition-transform duration-300"></i>
          <span class="text-[11px] font-extrabold tracking-widest text-gray-300 uppercase mb-2" style="font-family: 'Inter', sans-serif;">3RD ROW</span>
          <span class="text-xl text-white" style="font-family: 'Playfair Display', serif;">+ $25</span>
        </div>
      </div>
      <p class="text-center text-sm text-gray-500 italic mt-8" style="font-family: 'Inter', sans-serif;">Final price may vary depending on vehicle size and condition.</p>
    </div>

    <a href="#" class="inline-flex items-center gap-3 bg-gradient-to-r from-[#d39a4d] to-[#fdd78c] text-black py-4 px-10 hover:bg-[#fdd78c] hover:text-black transition-colors shadow-lg shadow-[#d39a4d]/30">
      <i class="ph-fill ph-map-pin text-xl"></i>
      <span class="text-sm font-bold tracking-widest uppercase" style="font-family: 'Inter', sans-serif;">WE COME TO YOU — MOBILE DETAILING</span>
    </a>

  </div>
</section>
