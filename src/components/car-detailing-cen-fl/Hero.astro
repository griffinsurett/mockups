---
import Logo from './Logo.astro';
---
<section class="relative w-full h-180 flex items-center justify-center text-center" style="margin-top: calc(-1 * var(--header-h, 72px))">
  <div class="absolute inset-0 z-0">
    <img src="/car-detailing-cen-fl/assets/images/hero.png" alt="Car interior detailing" class="w-full h-full object-cover object-center" />
    <div class="absolute inset-0 bg-black/60"></div>
  </div>

  <div class="relative z-10 flex flex-col items-center px-4 pt-28">
    <div class="hidden md:block">
      <Logo class="w-80 md:w-[420px] mb-6" />
    </div>

    <h1 class="text-3xl md:text-5xl text-white font-bold max-w-4xl leading-tight mb-6 drop-shadow-xl" style="text-shadow: 2px 2px 4px rgba(0,0,0,0.5); font-family: 'Playfair Display', serif;">
      RESTORE YOUR CHERISHED VEHICLE TO ITS ORIGINAL FACTORY FRESH GLORY.
    </h1>

    <p class="text-white text-lg md:text-xl font-bold tracking-[0.2em] uppercase mb-10 drop-shadow-md" style="font-family: 'Inter', sans-serif;">
      OBSESSED WITH THE DETAILS. COMMITTED TO THE RESULT.
    </p>

    <a href="/car-detailing-cen-fl/contact" class="border-2 border-white text-white font-bold text-sm tracking-widest py-3 px-8 hover:bg-white hover:text-black transition-colors duration-300 uppercase rounded-sm bg-black/20" style="font-family: 'Inter', sans-serif;">
      GET YOUR CAR DETAILED NOW
    </a>
  </div>
</section>
