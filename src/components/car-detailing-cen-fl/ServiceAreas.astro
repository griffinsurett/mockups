---
const areas = [
  "Daytona Beach", "Ormond Beach", "Port Orange", "New Smyrna Beach", "DeLand",
  "Orange City", "Deltona", "Sanford", "Lake Mary", "Longwood",
  "Altamonte Springs", "Casselberry", "Winter Springs", "Oviedo", "Orlando",
  "Winter Park", "Maitland", "Apopka", "Winter Garden", "Clermont",
  "Kissimmee", "St. Cloud", "Ocala", "The Villages", "Leesburg",
  "Mount Dora", "Eustis", "Tavares", "Deland", "Edgewater",
];
---

<section class="w-full bg-black">

  <div class="flex flex-col md:flex-row min-h-[540px]">

    <!-- Map -->
    <div class="w-full md:w-1/3 min-h-[360px] md:min-h-0">
      <iframe
        title="Central FLA. Auto Detail — Service Area"
        src="https://maps.google.com/maps?q=Central+Florida&output=embed&z=8"
        width="100%"
        height="100%"
        style="border:0; display:block; min-height:360px; filter: grayscale(1) invert(1) contrast(0.85);"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
    </div>

    <!-- Areas list -->
    <div class="w-full md:w-2/3 py-12 px-8 lg:px-14 flex flex-col justify-center border-l border-white/10">

      <p class="text-xs font-bold tracking-[0.3em] uppercase mb-3 bg-linear-to-r from-[#d39a4d] to-[#fdd78c] bg-clip-text text-transparent" style="font-family: 'Inter', sans-serif;">
        WE COME TO YOU
      </p>

      <h2 class="text-3xl md:text-4xl font-bold text-white mb-2 leading-tight" style="font-family: 'Playfair Display', serif;">
        Serving Central Florida
      </h2>

      <div class="w-12 h-[2px] bg-linear-to-r from-[#d39a4d] to-[#fdd78c] mb-8"></div>

      <ul class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-6 gap-y-3">
        {areas.map((area) => (
          <li class="flex items-center gap-2 text-sm font-semibold text-white/80">
            <span class="w-1.5 h-1.5 rounded-full bg-linear-to-r from-[#d39a4d] to-[#fdd78c] shrink-0" style="background: #d39a4d;"></span>
            {area}
          </li>
        ))}
      </ul>

      <p class="mt-8 text-xs text-white/40 font-medium" style="font-family: 'Inter', sans-serif;">
        Don't see your city? <a href="/car-detailing-cen-fl/contact" class="text-[#d39a4d] hover:text-[#fdd78c] transition-colors underline">Contact us</a> — we likely cover it.
      </p>

    </div>

  </div>

</section>
