---
import GalleryCarousel from "./GalleryCarousel";

const images = [
  { src: "/car-detailing-cen-fl/assets/images/gallery/black-car.jpeg",   alt: "Black car detail" },
  { src: "/car-detailing-cen-fl/assets/images/gallery/blue-car.jpeg",    alt: "Blue car detail" },
  { src: "/car-detailing-cen-fl/assets/images/gallery/chevy-bck.jpeg",   alt: "Chevy rear detail" },
  { src: "/car-detailing-cen-fl/assets/images/gallery/chevy-frnt.jpeg",  alt: "Chevy front detail" },
  { src: "/car-detailing-cen-fl/assets/images/gallery/gray-car.jpeg",    alt: "Gray car detail" },
  { src: "/car-detailing-cen-fl/assets/images/gallery/gray-car2.jpeg",   alt: "Gray car exterior" },
  { src: "/car-detailing-cen-fl/assets/images/gallery/radio.jpeg",       alt: "Interior radio detail" },
  { src: "/car-detailing-cen-fl/assets/images/gallery/red-car.jpeg",     alt: "Red car detail" },
  { src: "/car-detailing-cen-fl/assets/images/before-and-after/frnt-of-car1/aftr-front-ofcar.jpeg", alt: "Front of car after detail" },
  { src: "/car-detailing-cen-fl/assets/images/before-and-after/bck-of-car1/after-bck-of-car.jpeg",  alt: "Back of car after detail" },
  { src: "/car-detailing-cen-fl/assets/images/before-and-after/pink-wheel/pink-whel-aftr.jpeg",      alt: "Pink wheel after detail" },
];
---

<section id="gallery" class="w-full border-b-[6px] border-[#d39a4d]">
  <GalleryCarousel items={images} client:visible />
</section>
