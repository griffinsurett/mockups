---
import BaseLayout from "../../layouts/alert-sprinkler/BaseLayout.astro";
---

<BaseLayout title="Contact — Alert Sprinkler Co., Inc.">
  <main style="padding-top: 6rem;" class="max-w-4xl mx-auto px-6 py-24">

    <h1 class="text-4xl font-extrabold tracking-tight mb-4" style="color: #291715;">Contact Us</h1>
    <p class="text-base leading-relaxed mb-16" style="color: #5d3f3b;">
      For new installations, inspections, emergency repairs, or general inquiries — reach out to our team directly.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-16">

      <!-- Contact Info -->
      <div class="flex flex-col gap-8">
        <div>
          <h2 class="text-lg font-bold mb-3" style="color: #291715;">Office</h2>
          <p class="text-base" style="color: #5d3f3b;">
            1085 Cranbury South River Rd., Suite 1<br />
            Jamesburg, NJ 08831
          </p>
          <p class="mt-3 text-base" style="color: #5d3f3b;">
            <strong>Phone:</strong> <a href="tel:7325211666" class="text-as-primary hover:underline">732-521-1666</a><br />
            <strong>Fax:</strong> 732-521-2618
          </p>
        </div>

        <div>
          <h2 class="text-lg font-bold mb-3" style="color: #291715;">Management</h2>
          <ul class="flex flex-col gap-4 text-base" style="color: #5d3f3b;">
            <li>
              <strong style="color: #291715;">Chad Blum</strong> — President<br />
              <a href="mailto:chad@alertsprinkler.com" class="text-as-primary hover:underline">chad@alertsprinkler.com</a>
            </li>
            <li>
              <strong style="color: #291715;">Steve Toth</strong> — Vice President<br />
              <a href="mailto:steve@alertsprinkler.com" class="text-as-primary hover:underline">steve@alertsprinkler.com</a>
            </li>
            <li>
              <strong style="color: #291715;">Taran Fedor</strong> — Office Manager<br />
              <a href="mailto:taran@alertsprinkler.com" class="text-as-primary hover:underline">taran@alertsprinkler.com</a>
            </li>
          </ul>
        </div>
      </div>

      <!-- Request a Call Back form placeholder -->
      <div>
        <h2 class="text-lg font-bold mb-6" style="color: #291715;">Request A Call Back</h2>
        <form class="flex flex-col gap-4">
          <input
            type="text"
            placeholder="Your Name"
            class="border border-as-border px-4 py-3 text-sm w-full"
            style="color: #291715; background: #fff8f7;"
          />
          <input
            type="tel"
            placeholder="Phone Number"
            class="border border-as-border px-4 py-3 text-sm w-full"
            style="color: #291715; background: #fff8f7;"
          />
          <input
            type="email"
            placeholder="Email Address"
            class="border border-as-border px-4 py-3 text-sm w-full"
            style="color: #291715; background: #fff8f7;"
          />
          <textarea
            placeholder="Tell us about your project or inquiry"
            rows="4"
            class="border border-as-border px-4 py-3 text-sm w-full resize-none"
            style="color: #291715; background: #fff8f7;"
          ></textarea>
          <button type="submit" class="as-btn-primary px-8 py-4 text-base w-full">
            Request A Call Back
          </button>
        </form>
      </div>

    </div>
  </main>
</BaseLayout>
