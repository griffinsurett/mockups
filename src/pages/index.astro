---
import Base from "../layouts/Base.astro";

const mockups = [
  {
    slug: "ebersole",
    name: "C. Ebersole Enterprises",
    description: "General Contracting · Lancaster County, PA",
    type: "HTML",
  },
  {
    slug: "actionrestoration",
    name: "Action Restoration",
    description: "Water, Fire & Mold Restoration Services",
    type: "HTML",
  },
];
---

<Base title="Client Mockups">
  <main class="max-w-4xl mx-auto px-6 py-16">
    <header class="mb-12">
      <h1 class="text-4xl font-bold tracking-tight mb-2">Client Mockups</h1>
      <p class="text-gray-400">Select a client to preview their site mockup.</p>
    </header>

    <ul class="grid gap-4 sm:grid-cols-2">
      {mockups.map((m) => (
        <li>
          <a
            href={`/${m.slug}`}
            class="block rounded-xl border border-gray-800 bg-gray-900 p-6 hover:border-gray-600 hover:bg-gray-800 transition-colors group"
          >
            <div class="flex items-start justify-between gap-4">
              <div>
                <h2 class="font-semibold text-lg group-hover:text-white">{m.name}</h2>
                <p class="text-sm text-gray-400 mt-1">{m.description}</p>
              </div>
              <span class="shrink-0 text-xs font-mono px-2 py-1 rounded bg-gray-800 text-gray-400 border border-gray-700">
                {m.type}
              </span>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </main>
</Base>
